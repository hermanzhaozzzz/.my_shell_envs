resolve_script_path() {
    local source_path="$1"
    local source_dir=""

    while [ -L "$source_path" ]; do
        source_dir="$(CDPATH= cd -- "$(dirname "$source_path")" && pwd)"
        source_path="$(readlink "$source_path")"
        case "$source_path" in
            /*) ;;
            *) source_path="$source_dir/$source_path" ;;
        esac
    done

    source_dir="$(CDPATH= cd -- "$(dirname "$source_path")" && pwd)"
    printf '%s/%s\n' "$source_dir" "$(basename "$source_path")"
}

