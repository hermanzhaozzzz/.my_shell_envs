        clash|direct-egress)
            printf '%s\n' "${MSE_PROXY_MODE}"
            ;;
        *)
            printf '%s\n' "clash"
            ;;
    esac
}

_mse_proxy_default_no_proxy() {
    printf '%s\n' "192.168.59.102,192.168.59.103"
}

_mse_proxy_http_url() {
    if [[ "$(_mse_proxy_mode_setting)" == "direct-egress" ]]; then
        printf 'socks5://%s:%s\n' "${MSE_PROXY_HOST}" "${MSE_PROXY_PORT}"
    else
        printf 'http://%s:%s\n' "${MSE_PROXY_HOST}" "${MSE_PROXY_PORT}"
    fi
}

_mse_proxy_socks_url() {
    printf 'socks5://%s:%s\n' "${MSE_PROXY_HOST}" "${MSE_PROXY_PORT}"
}

_mse_proxy_autossh_bin() {
    command -v autossh 2>/dev/null
}

_mse_proxy_proxychains_bin() {
    command -v proxychains4 2>/dev/null || command -v proxychains 2>/dev/null
}

_mse_proxy_port_open() {
    command -v nc >/dev/null 2>&1 || return 1
    nc -z "${1:-127.0.0.1}" "${2:-${MSE_PROXY_PORT}}" >/dev/null 2>&1
}

_mse_proxy_is_compute_node() {
    local host_name=""
    local direct_host=""

    host_name="$(hostname)"
    [[ "${host_name}" == login* ]] && return 1
    for direct_host in ${(s: :)MSE_PROXY_DIRECT_HOSTS}; do
        [[ -n "${direct_host}" && "${host_name}" == "${direct_host}" ]] && return 1
    done
    [[ "${host_name}" =~ '^c[0-9]+b[0-9]+n[0-9]+$' ]] && return 0
    [[ -n "${SLURM_JOB_ID:-}" ]] && return 0
    return 1
}

_mse_proxy_upstream_host() {
    local client_ip=""
    local resolved_host=""

    if [[ -n "${MSE_PROXY_UPSTREAM_HOST:-}" ]]; then
        printf '%s\n' "${MSE_PROXY_UPSTREAM_HOST}"
        return 0
    fi

    if [[ -n "${SSH_CONNECTION:-}" ]]; then
        client_ip="${SSH_CONNECTION%% *}"
        if [[ -n "${client_ip}" ]]; then
            if command -v getent >/dev/null 2>&1; then
                resolved_host="$(getent hosts "${client_ip}" 2>/dev/null | awk 'NR==1 {print $2}')"
            fi
            if [[ -n "${resolved_host}" ]]; then
                printf '%s\n' "${resolved_host}"
            else
                printf '%s\n' "${client_ip}"
            fi
            return 0
        fi
    fi

    return 1
}

_mse_proxy_tunnel_pattern() {
    local upstream_host="$1"
    if [[ "$(_mse_proxy_mode_setting)" == "direct-egress" ]]; then
        printf 'autossh .* -D 127.0.0.1:%s %s' "${MSE_PROXY_PORT}" "${upstream_host}"
    else
        printf 'autossh .*127.0.0.1:%s:127.0.0.1:%s %s' "${MSE_PROXY_PORT}" "${MSE_PROXY_PORT}" "${upstream_host}"
    fi
}

_mse_proxy_tunnel_pid() {
    local upstream_host="$1"
    pgrep -f "$(_mse_proxy_tunnel_pattern "${upstream_host}")" 2>/dev/null | head -n 1
}

_mse_proxy_enable_env() {
    local http_url="$(_mse_proxy_http_url)"
    local socks_url="$(_mse_proxy_socks_url)"

    export https_proxy="${http_url}"
    export http_proxy="${http_url}"
    export all_proxy="${socks_url}"
    export no_proxy="${MSE_PROXY_NO_PROXY:-$(_mse_proxy_default_no_proxy)}"

    echo -e '\texport \033[1;35mhttps_proxy\033[0m='${https_proxy}
    echo -e '\texport \033[1;35mhttp_proxy\033[0m='${http_proxy}
    echo -e '\texport \033[1;35mall_proxy\033[0m='${all_proxy}
    echo -e '\texport \033[1;35mno_proxy\033[0m='${no_proxy}
}

_mse_proxy_disable_env() {
    unset https_proxy
    unset http_proxy
    unset all_proxy
}

_mse_proxy_runtime_proxychains_conf() {
    local runtime_conf="${TMPDIR:-/tmp}/mse-proxychains-${UID:-$(id -u)}-${MSE_PROXY_PORT}.conf"
    cat > "${runtime_conf}" <<EOF
strict_chain
proxy_dns
remote_dns_subnet 224
tcp_read_time_out 15000
tcp_connect_time_out 8000

[ProxyList]
socks5 ${MSE_PROXY_HOST} ${MSE_PROXY_PORT}
EOF
    printf '%s\n' "${runtime_conf}"
}

_mse_proxy_start_tunnel() {
    local upstream_host="$1"
    local autossh_bin=""
    local existing_pid=""
    local proxy_mode=""
    local forward_args=()

    autossh_bin="$(_mse_proxy_autossh_bin)"
    [[ -n "${autossh_bin}" ]] || {
        echo "proxy.on: autossh not found in PATH"
        return 1
    }
    proxy_mode="$(_mse_proxy_mode_setting)"

    existing_pid="$(_mse_proxy_tunnel_pid "${upstream_host}")"
    if [[ -n "${existing_pid}" ]]; then
        echo "proxy tunnel already running via ${upstream_host} (pid=${existing_pid})"
        return 0
    fi

    if _mse_proxy_port_open "127.0.0.1" "${MSE_PROXY_PORT}"; then
        echo "proxy.on: local ${MSE_PROXY_PORT} is already listening, refusing to overwrite it"
        return 1
    fi

    if [[ "${proxy_mode}" == "direct-egress" ]]; then
        forward_args=(-D "127.0.0.1:${MSE_PROXY_PORT}")
    else
        forward_args=(-L "127.0.0.1:${MSE_PROXY_PORT}:127.0.0.1:${MSE_PROXY_PORT}")
    fi

    AUTOSSH_GATETIME=0 AUTOSSH_POLL=30 AUTOSSH_FIRST_POLL=30 \
        "${autossh_bin}" -M 0 -f -N \
        -o ExitOnForwardFailure=yes \
        -o ServerAliveInterval=30 \
        -o ServerAliveCountMax=3 \
        -o StrictHostKeyChecking=no \
        "${forward_args[@]}" \
        "${upstream_host}" || {
            echo "proxy.on: failed to start autossh tunnel via ${upstream_host}"
            return 1
        }

    sleep 1
    if ! _mse_proxy_port_open "127.0.0.1" "${MSE_PROXY_PORT}"; then
        echo "proxy.on: tunnel start returned but local port ${MSE_PROXY_PORT} is still unavailable"
        return 1
    fi

    echo "proxy tunnel started via ${upstream_host}"
}

_mse_proxy_stop_tunnel() {
    local upstream_host="$1"
    local pids=""

    pids="$(pgrep -f "$(_mse_proxy_tunnel_pattern "${upstream_host}")" 2>/dev/null | tr '\n' ' ')"
    [[ -n "${pids}" ]] || return 0
    kill ${=pids} >/dev/null 2>&1 || true
}

_mse_proxy_mode() {
    if _mse_proxy_is_compute_node; then
        printf '%s\n' "compute"
    elif _mse_proxy_port_open "127.0.0.1" "${MSE_PROXY_PORT}"; then
        printf '%s\n' "direct"
    else
        printf '%s\n' "direct"
    fi
}

_func_proxy_on() {
    local mode=""
    local upstream_host=""
    local proxy_mode=""

    mode="$(_mse_proxy_mode)"
    proxy_mode="$(_mse_proxy_mode_setting)"

    if [[ "${mode}" == "compute" ]]; then
        upstream_host="$(_mse_proxy_upstream_host)" || {
            echo "proxy.on: failed to detect upstream login host; set MSE_PROXY_UPSTREAM_HOST manually"
            return 1
        }
        _mse_proxy_start_tunnel "${upstream_host}" || return 1
        echo "proxy mode: ${proxy_mode}"
        if [[ "${proxy_mode}" == "direct-egress" ]]; then
            echo "proxy tunnel type: dynamic-socks"
        else
            echo "proxy tunnel type: local-forward"
        fi
        echo "proxy upstream: ${upstream_host}:${MSE_PROXY_PORT}"
    else
        echo "proxy mode: ${proxy_mode}"
        echo "proxy node role: direct"
        if [[ "${proxy_mode}" == "direct-egress" ]]; then
            echo "proxy.on: direct-egress mode is mainly for compute nodes borrowing the login node network"
            return 1
        fi
        if ! _mse_proxy_port_open "127.0.0.1" "${MSE_PROXY_PORT}"; then
            echo "proxy.on: warning: local proxy ${MSE_PROXY_PORT} is not listening yet"
        fi
    fi

    _mse_proxy_enable_env
}

_func_proxy_off() {
    local upstream_host=""

    _mse_proxy_disable_env
    git config --global --unset https.proxy 2>/dev/null
    git config --global --unset http.proxy 2>/dev/null

    if _mse_proxy_is_compute_node; then
        upstream_host="$(_mse_proxy_upstream_host 2>/dev/null || true)"
        if [[ -n "${upstream_host}" ]]; then
            _mse_proxy_stop_tunnel "${upstream_host}"
        fi
    fi
}

_func_proxy_status() {
    local mode=""
    local upstream_host=""
    local tunnel_pid=""
    local proxy_mode=""

    mode="$(_mse_proxy_mode)"
    proxy_mode="$(_mse_proxy_mode_setting)"
    echo "proxy node role: ${mode}"
    echo "proxy mode: ${proxy_mode}"
    echo "proxy env http: ${http_proxy:-<unset>}"
    echo "proxy env socks: ${all_proxy:-<unset>}"
    echo "autossh: $(_mse_proxy_autossh_bin || echo '<missing>')"
    echo "proxychains: $(_mse_proxy_proxychains_bin || echo '<missing>')"
    echo "proxychains conf: $(_mse_proxy_runtime_proxychains_conf)"

    if _mse_proxy_is_compute_node; then
        upstream_host="$(_mse_proxy_upstream_host 2>/dev/null || true)"
        echo "proxy upstream: ${upstream_host:-<unknown>}"
        if [[ "${proxy_mode}" == "direct-egress" ]]; then
            echo "proxy tunnel type: dynamic-socks"
        else
            echo "proxy tunnel type: local-forward"
        fi
        if [[ -n "${upstream_host}" ]]; then
            tunnel_pid="$(_mse_proxy_tunnel_pid "${upstream_host}")"
            echo "proxy tunnel pid: ${tunnel_pid:-<not running>}"
        fi
    fi

    if _mse_proxy_port_open "127.0.0.1" "${MSE_PROXY_PORT}"; then
        echo "local proxy port ${MSE_PROXY_PORT}: listening"
    else
        echo "local proxy port ${MSE_PROXY_PORT}: closed"
    fi
}

_func_proxy_test() {
    local runtime_conf=""
    local proxy_mode=""
    local urls=()
    local url=""
    local short=""
    local code=""
    local failed=0

    command -v curl >/dev/null 2>&1 || {
        echo "proxy.test: curl not found"
        return 1
    }
    runtime_conf="$(_mse_proxy_runtime_proxychains_conf)"
    proxy_mode="$(_mse_proxy_mode_setting)"

    if [[ "${proxy_mode}" == "direct-egress" ]]; then
        urls=(
            "https://www.google.com.hk|google.com.hk"
            "https://www.baidu.com|baidu.com"
            "https://api.openai.com|openai"
            "https://api.anthropic.com|claude"
            "https://z.ai|z.ai"
        )
    else
        urls=(
            "https://www.baidu.com|baidu.com"
            "https://www.google.com.hk|google.com.hk"
            "https://api.openai.com|openai"
            "https://api.anthropic.com|claude"
            "https://z.ai|z.ai"
        )
    fi

    echo "== curl via env proxy =="
    for url in "${urls[@]}"; do
        short="${url#*|}"
        url="${url%%|*}"
        code=$(curl -I -s -o /dev/null -w '%{http_code}' --max-time 8 "${url}" 2>/dev/null)
        if [[ "${code}" != "000" && -n "${code}" ]]; then
            printf '  \033[1;32m%-15s\033[0m %s (HTTP %s)\n' "OK" "${short}" "${code}"
        else
            printf '  \033[1;31m%-15s\033[0m %s (HTTP %s)\n' "FAIL" "${short}" "${code:-timeout}"
            failed=$((failed + 1))
        fi
    done

    if [[ -n "$(_mse_proxy_proxychains_bin)" ]]; then
        echo "== curl via proxychains =="
        for url in "${urls[@]}"; do
            short="${url#*|}"
            url="${url%%|*}"
            code=$("$(_mse_proxy_proxychains_bin)" -f "${runtime_conf}" curl -I -s -o /dev/null -w '%{http_code}' --max-time 8 "${url}" 2>/dev/null)
            if [[ "${code}" != "000" && -n "${code}" ]]; then
                printf '  \033[1;32m%-15s\033[0m %s (HTTP %s)\n' "OK" "${short}" "${code}"
            else
                printf '  \033[1;31m%-15s\033[0m %s (HTTP %s)\n' "FAIL" "${short}" "${code:-timeout}"
                failed=$((failed + 1))
            fi
        done
    fi

    return ${failed}
}

_func_proxy_exec() {
    local proxychains_bin=""
    local runtime_conf=""

    proxychains_bin="$(_mse_proxy_proxychains_bin)"
    runtime_conf="$(_mse_proxy_runtime_proxychains_conf)"
    [[ -n "${proxychains_bin}" ]] || {
        echo "proxy.exec: proxychains4 not found in PATH"
        return 1
    }
    [[ $# -gt 0 ]] || {
        echo "usage: proxy.exec <command> [args...]"
        return 1
    }

    "${proxychains_bin}" -f "${runtime_conf}" "$@"
}

_mse_proxy_auto_init() {
    local mode=""

    case "${MSE_SLURM_NODE_PROXY_AUTO_ENABLE}" in
        false|FALSE|False|no|NO|No|off|OFF|Off)
            return 0
            ;;
    esac

    [[ -n "${http_proxy:-}" || -n "${https_proxy:-}" || -n "${all_proxy:-}" ]] && return 0

    mode="$(_mse_proxy_mode)"

    if [[ "${mode}" == "compute" ]]; then
        if _func_proxy_on; then
            echo '!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!'
            echo -e '\t\033[1;32mproxy auto-enabled\033[0m on compute node'
            echo -e '\ttest with \033[1;35mproxy.test\033[0m (baidu, google.com.hk, openai, claude, z.ai)'
            echo '!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!'
        else
            echo '!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!'
            echo -e '\t\033[1;31mproxy auto-enable failed\033[0m on compute node'
            echo -e '\tset \033[1;35mMSE_PROXY_UPSTREAM_HOST\033[0m manually, then run \033[1;35mproxy.on\033[0m'
            echo '!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!'
        fi
        return 0
    fi

    if _mse_proxy_port_open "127.0.0.1" "${MSE_PROXY_PORT}"; then
        echo '!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!'
        echo -e '\t\033[1;33mproxy NOT auto-enabled\033[0m on login/direct node'
        echo -e '\trun \033[1;35mproxy.on\033[0m to enable when needed'
        echo '!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!'
    fi
}

