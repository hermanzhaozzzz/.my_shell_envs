step_code_notify() {
    if [ "$platform_family" != "MacOS" ]; then
        log_warn "skip code-notify on platform: $platform"
        return 0
    fi

    print_section "ensure code-notify is installed"

    if command -v cn >/dev/null 2>&1; then
        log_ok "code-notify already installed at $(fmt_path "$(command -v cn)")"
    else
        log_info "code-notify not found, installing via brew"
        if command -v brew >/dev/null 2>&1; then
            brew tap mylee04/tools || log_warn "failed to tap mylee04/tools"
            brew install code-notify || fail "failed to install code-notify via brew"
        else
            fail "Homebrew is required to install code-notify but was not found in PATH"
        fi
    fi

    log_info "configuring code-notify sound"
    cn sound set /System/Library/Sounds/Blow.aiff || log_warn "failed to set code-notify sound"

    log_info "adding code-notify alerts"
    cn alerts add permission_prompt || log_warn "failed to add permission_prompt alert"
    cn alerts add auth_success || log_warn "failed to add auth_success alert"

    log_info "enabling code-notify"
    cn on || log_warn "failed to enable code-notify"

    log_ok "code-notify is ready"
}

step_powershell() {
    local win_current_host_profile
    local win_profile_root
    local repo_profile
    local bootstrap_status=0

    if [ "$platform" != "Windows" ]; then
        log_warn "skip PowerShell profile on platform: $platform"
        return 0
    fi

    require_cmd pwsh

    win_profile_root="$(resolve_windows_powershell_profile_dir)" || fail "failed to resolve the Windows PowerShell user profile directory"
    win_current_host_profile="$win_profile_root/Microsoft.PowerShell_profile.ps1"
    repo_profile="$REPO_PATH/powershell/Microsoft.PowerShell_profile.ps1"

    mkdir -p "$win_profile_root"
    log_info "link PowerShell profile to $(fmt_path "$win_profile_root")"
    if ! MSE_POWERSHELL_BOOTSTRAP=1 pwsh -NoProfile -ExecutionPolicy Bypass -File "$repo_profile"; then
        bootstrap_status=$?
        log_warn "PowerShell bootstrap returned exit code $bootstrap_status; profile will still be linked"
    fi
    backup_and_link_windows_native "$repo_profile" "$win_current_host_profile"
    log_ok "PowerShell profile linked from $(fmt_path "$repo_profile")"
}

command_deploy() {
    parse_deploy_args "$@"

    mkdir -p "$BIN_PATH"

    case "$git_method" in
        https)
            url_root="https://github.com/"
            ;;
        ssh)
            url_root="git@github.com:"
            ;;
        *)
            fail "git_method must be one of <https|ssh>"
            ;;
    esac

    SELECTED_STEPS=""
    detect_platform_settings

    if [ "$list_steps" -eq 1 ]; then
        print_available_steps
        exit 0
    fi

    install_global_wrapper

    print_section "deployment context"
    print_kv "git" "$git_method"
    print_kv "mode" "$deploy_mode"
    print_kv "platform" "$platform"

    cleanup_legacy_spyder

    choose_steps
    choose_proxy_region

    if step_selected "cluster_proxy_tools"; then
        print_kv "region" "$region"
        print_kv "proxy mode" "$proxy_mode"
        print_kv "proxy port" "$proxy_port"
    fi

    if [ "$platform" = "Windows" ] && [ -z "$SELECTED_STEPS" ] && [ "$use_zprofile_template" -eq 0 ]; then
        log_warn "no steps selected, nothing to do"
        exit 0
    fi

    print_selected_steps
    print_deploy_warnings
    sync_optional_bin_entries

    ensure_non_windows_zsh_core

    run_step "micromamba" step_micromamba
    run_step "condarc" step_condarc
    run_step "pip" step_pip
    run_step "vim" step_vim
    run_step "nvim" step_nvim
    run_step "jcat" step_jcat
    run_step "wd" step_wd
    run_step "sqtop" step_sqtop
    run_step "powershell" step_powershell
    run_step "code_notify" step_code_notify
    run_step "cluster_proxy_tools" step_cluster_proxy_tools

    if [ "$use_zprofile_template" -eq 1 ]; then
        apply_zprofile_template
    fi

    persist_deploy_settings

    print_section "deployment complete"
    log_ok "all selected steps finished"
    print_selected_steps

    print_section "commands"
    if [ "$platform" = "Windows" ]; then
        print_list_item "run updates in the repo: git-bash ./mse update"
    else
        print_list_item "inside the repo: ./mse deploy"
        print_list_item "inside the repo: ./mse update"
        print_list_item "global after opening a new zsh terminal: mse deploy"
        print_list_item "global after opening a new zsh terminal: mse update"
    fi

    print_section "next steps"
    if [ "$platform" = "Windows" ]; then
        if step_selected "powershell"; then
            print_path_item "open PowerShell to use your environment"
        fi
    else
        print_list_item "open a new zsh session or run: exec zsh"
        if [ "$use_zprofile_template" -eq 1 ]; then
            print_list_item "review ~/.zprofile and replace personal values before long-term use"
        else
            print_list_item "create your own ~/.zprofile for PATH, proxy, tokens, and host-specific aliases"
        fi
    fi

    if step_selected "micromamba"; then
        print_list_item "PowerShell: conda env update -n base -f $CONDA_ENVS/base.yml --prune"
    fi

    if [ "$platform" != "Windows" ]; then
        print_list_item "your global command directory is: $BIN_PATH"
    fi

    print_section "tips"
    print_list_item "raise issue on https://github.com/hermanzhaozzzz/.my_shell_envs/issues"

    if [ "$platform" = "Windows" ]; then
        if [ -t 0 ]; then
            log_warn "press any key to exit"
            IFS= read -r -n 1 -s _
            printf '\n'
        fi
    fi
}

command_update() {
    parse_update_args "$@"

    [ -d "$REPO_PATH/.git" ] || fail "mse update now requires a git clone of this repository. Please reinstall with git clone, then rerun './mse update'."
    update_from_git
}

main() {
    local command="${1:-help}"

    case "$command" in
        help|-h|--help)
            print_root_usage
            ;;
        deploy)
            shift
            command_deploy "$@"
            ;;
        update)
            shift
            command_update "$@"
            ;;
        *)
            fail "unknown command: $command. Run './mse -h' for help."
            ;;
    esac
}

main "$@"
