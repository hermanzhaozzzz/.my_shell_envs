fail() {
    printf '%s %s\n' "$(badge "$COLOR_RED" "ERR")" "$*" >&2
    exit 1
}

setup_colors() {
    local esc
    esc="$(printf '\033')"

    COLOR_RESET=""
    COLOR_BOLD=""
    COLOR_BLUE=""
    COLOR_CYAN=""
    COLOR_GREEN=""
    COLOR_YELLOW=""
    COLOR_RED=""
    COLOR_MAGENTA=""
    COLOR_DIM=""

    if [ -t 1 ] && [ "${TERM:-}" != "dumb" ]; then
        COLOR_RESET="${esc}[0m"
        COLOR_BOLD="${esc}[1m"
        COLOR_DIM="${esc}[2m"
        COLOR_BLUE="${esc}[34m"
        COLOR_CYAN="${esc}[36m"
        COLOR_GREEN="${esc}[32m"
        COLOR_YELLOW="${esc}[33m"
        COLOR_RED="${esc}[31m"
        COLOR_MAGENTA="${esc}[35m"
    fi
}

badge() {
    local color="$1"
    local text="$2"
    printf '%s[%s]%s' "${color}${COLOR_BOLD}" "$text" "$COLOR_RESET"
}

fmt_path() {
    printf '%s%s%s' "${COLOR_CYAN}" "$1" "$COLOR_RESET"
}

fmt_key() {
    printf '%s%s%s' "${COLOR_MAGENTA}${COLOR_BOLD}" "$1" "$COLOR_RESET"
}

fmt_step() {
    printf '%s%s%s' "${COLOR_MAGENTA}${COLOR_BOLD}" "$1" "$COLOR_RESET"
}

log_info() {
    printf '%s %s\n' "$(badge "$COLOR_BLUE" "INFO")" "$*"
}

log_ok() {
    printf '%s %s\n' "$(badge "$COLOR_GREEN" " OK ")" "$*"
}

log_warn() {
    printf '%s %s\n' "$(badge "$COLOR_YELLOW" "WARN")" "$*"
}

print_path_item() {
    printf '  - %s\n' "$(fmt_path "$1")"
}

print_list_item() {
    printf '  - %s\n' "$1"
}

print_kv() {
    printf '  %s %s\n' "$(fmt_key "$1")" "$2"
}

can_prompt_user() {
    [ -t 0 ] && [ -t 1 ]
}

detect_current_shell_name() {
    local shell_name=""

    if [ -n "${SHELL:-}" ]; then
        shell_name="${SHELL##*/}"
    fi

    if [ -z "$shell_name" ] || [ "$shell_name" = "sh" ]; then
        shell_name="$(ps -p "$PPID" -o comm= 2>/dev/null | awk '{print $1}' | sed 's#.*/##')"
    fi

    printf '%s\n' "$shell_name"
}

detect_shell_rc_path() {
    case "$1" in
        bash) printf '%s\n' "$HOME/.bashrc" ;;
        zsh) printf '%s\n' "$HOME/.zshrc" ;;
        *) return 1 ;;
    esac
}

write_zsh_handoff_block() {
    local rc_path="$1"
    local zsh_path="$2"
    local tmp_file
    local backup_path=""

    mkdir -p "$(dirname "$rc_path")"

    if [ -f "$rc_path" ]; then
        backup_path="${rc_path}.mse.bak.$(date +%Y%m%d_%H%M%S)"
        cp -f "$rc_path" "$backup_path" 2>/dev/null || true
        log_info "backed up existing shell config to $(fmt_path "$backup_path")"
    fi

    tmp_file="$(mktemp "${TMPDIR:-/tmp}/mse-shell.XXXXXX")" || fail "failed to create temporary file for shell handoff config"

    if [ -f "$rc_path" ]; then
        awk '
            BEGIN { skip=0 }
            /^# >>> MSE auto-enter zsh >>>$/ { skip=1; next }
            /^# <<< MSE auto-enter zsh <<<$/{ skip=0; next }
            skip == 0 { print }
        ' "$rc_path" > "$tmp_file"
    else
        : > "$tmp_file"
    fi

    cat >>"$tmp_file" <<EOF
# >>> MSE auto-enter zsh >>>
if [ -x "$zsh_path" ] && [ -z "\${MSE_AUTO_ENTER_ZSH:-}" ]; then
    export SHELL="$zsh_path"
    export MSE_AUTO_ENTER_ZSH=1
    exec "$zsh_path" -l
fi
# <<< MSE auto-enter zsh <<<
EOF

    mv "$tmp_file" "$rc_path" || fail "failed to update shell config at $rc_path"
    export SHELL="$zsh_path"
    log_ok "current shell handoff added to $(fmt_path "$rc_path")"
}

offer_zsh_handoff_setup() {
    local zsh_path="$1"
    local current_shell_name="$2"
    local rc_path=""
    local answer=""

    if [ "$current_shell_name" = "zsh" ]; then
        log_info "current shell already looks like zsh; skipping shell config injection"
        return 0
    fi

    if ! can_prompt_user; then
        log_warn "cannot prompt in this session; skipping shell config injection"
        log_warn "recommended: add an auto-enter zsh block to your ${current_shell_name:-current shell} config manually"
        return 0
    fi

    rc_path="$(detect_shell_rc_path "$current_shell_name" 2>/dev/null || true)"

    print_section "zsh handoff setup"
    log_warn "this environment is designed to run inside zsh"

    if [ -n "$rc_path" ]; then
        print_list_item "your current login shell appears to be: $current_shell_name"
        print_list_item "MSE can append an auto-enter zsh block to: $rc_path"
        print_list_item "this makes future interactive $current_shell_name sessions jump into zsh automatically"

        while :; do
            printf '%s add zsh handoff to %s? [y/N]: ' "$(badge "$COLOR_BLUE" "ASK")" "$(fmt_path "$rc_path")"
            read answer || break
            case "$answer" in
                y|Y|yes|YES)
                    write_zsh_handoff_block "$rc_path" "$zsh_path"
                    return 0
                    ;;
                n|N|no|NO|"")
                    log_warn "skipping shell config injection"
                    print_list_item "recommended: rerun deploy later and retry chsh, or add an auto-enter zsh block to $rc_path yourself"
                    return 0
                    ;;
            esac
        done
    else
        log_warn "could not map current shell '$current_shell_name' to a known rc file"
        print_list_item "recommended: configure your login shell to start zsh automatically, then rerun deploy if needed"
    fi

    return 0
}

print_section() {
    printf '\n%s==>%s %b\n' "${COLOR_BLUE}${COLOR_BOLD}" "${COLOR_RESET}" "$1"
}

describe_step() {
    case "$1" in
        micromamba)
            if [ "$platform" = "Windows" ]; then
                echo "link conda env yml files and prepare PowerShell micromamba integration"
            else
                echo "install micromamba and link conda env yml files"
            fi
            ;;
        condarc) echo "link ~/.condarc to the repo config" ;;
        pip) echo "link pip.conf" ;;
        vim) echo "clone or update vim-for-coding" ;;
        nvim) echo "clone or update MyLazyVim" ;;
        jcat) echo "build and link jcat" ;;
        wd) echo "clone or update Wudao-dict" ;;
        sqtop) echo "install sqtop for Slurm queue monitoring" ;;
        powershell) echo "set the PowerShell profile on Windows" ;;
        code_notify) echo "install code-notify and configure macOS terminal alerts" ;;
        cluster_proxy_tools) echo "build autossh/proxychains and prepare cluster proxy tooling" ;;
        *) echo "custom step" ;;
    esac
}

append_selected_step() {
    local step="$1"
    if [ -z "$SELECTED_STEPS" ]; then
        SELECTED_STEPS="$step"
    else
        SELECTED_STEPS="$SELECTED_STEPS $step"
    fi
}

step_selected() {
    local target="$1"
    local step
    for step in $SELECTED_STEPS; do
        if [ "$step" = "$target" ]; then
            return 0
        fi
    done
    return 1
}

step_supported_on_platform() {
    case "$1" in
        powershell)
            [ "$platform" = "Windows" ]
            ;;
        jcat|rust)
            [ "$platform" != "Windows" ]
            ;;
        sqtop)
            [ "$platform" = "Linux" ]
            ;;
        code_notify)
            [ "$platform_family" = "MacOS" ]
            ;;
        *)
            return 0
            ;;
    esac
}

setup_colors

print_available_steps() {
    local step
    print_section "available steps"
    print_kv "base" "requires zsh in PATH, then installs Rust, repo-managed CLI tools, Oh My Zsh, ~/.zshrc, and default shell switch"
    for step in $AVAILABLE_STEPS; do
        if ! step_supported_on_platform "$step"; then
            continue
        fi
        printf '  - %-10b %s\n' "$(fmt_step "$step")" "$(describe_step "$step")"
    done
}

known_step() {
    local known
    for known in $AVAILABLE_STEPS; do
        if [ "$known" = "$1" ]; then
            return 0
        fi
    done
    return 1
}

strip_env_quotes() {
    local value="$1"

    case "$value" in
        \"*\")
            value="${value#\"}"
            value="${value%\"}"
            ;;
        \'*\')
            value="${value#\'}"
            value="${value%\'}"
            ;;
    esac

    printf '%s\n' "$value"
}

filter_known_steps() {
    local input_steps="$1"
    local filtered=""
    local step

    for step in $input_steps; do
        if known_step "$step"; then
            if [ -z "$filtered" ]; then
                filtered="$step"
            else
                filtered="$filtered $step"
            fi
        else
            log_warn "ignoring unknown saved step in $(fmt_path "$METADATA_FILE"): $step"
        fi
    done

    printf '%s\n' "$filtered"
}

step_env_key() {
    printf 'MSE_STEP_%s\n' "$(printf '%s' "$1" | tr '[:lower:]' '[:upper:]')"
}

step_from_env_key() {
    local key="$1"
    local step

    for step in $AVAILABLE_STEPS; do
        if [ "$(step_env_key "$step")" = "$key" ]; then
            printf '%s\n' "$step"
            return 0
        fi
    done

    return 1
}

normalize_bool_value() {
    case "$1" in
        1|true|TRUE|True|yes|YES|Yes|on|ON|On)
            printf '1\n'
            ;;
        0|false|FALSE|False|no|NO|No|off|OFF|Off|"")
            printf '0\n'
            ;;
        *)
            return 1
            ;;
    esac
}

bool_string() {
    if [ "$1" -eq 1 ]; then
        printf 'true\n'
    else
        printf 'false\n'
    fi
}

detect_current_branch() {
    local current_branch=""

    if [ -d "$REPO_PATH/.git" ]; then
        current_branch="$(git -C "$REPO_PATH" branch --show-current 2>/dev/null || true)"
    fi

    if [ -n "$current_branch" ]; then
        printf '%s\n' "$current_branch"
    else
        printf '%s\n' "$DEFAULT_BRANCH"
    fi
}

load_persisted_deploy_settings() {
    local line=""
    local key=""
    local value=""
    local step=""
    local bool_value=""
    local legacy_selected_steps=""

    persisted_git_method="https"
    persisted_deploy_mode="fast"
    persisted_use_zprofile_template=0
    persisted_selected_steps=""
    persisted_default_branch="$DEFAULT_BRANCH"
    persisted_region="china"
    persisted_proxy_mode="clash"
    persisted_proxy_port="8234"

    [ -f "$METADATA_FILE" ] || return 0

    while IFS= read -r line || [ -n "$line" ]; do
        line="$(printf '%s' "$line" | sed 's/[[:space:]]*#.*$//; s/^[[:space:]]*//; s/[[:space:]]*$//')"
        [ -n "$line" ] || continue

        key="${line%%=*}"
        value="${line#*=}"
        value="$(strip_env_quotes "$value")"

        case "$key" in
            MSE_GIT_METHOD)
                persisted_git_method="$value"
                ;;
            MSE_DEPLOY_MODE)
                persisted_deploy_mode="$value"
                ;;
            MSE_USE_ZPROFILE_TEMPLATE)
                if bool_value="$(normalize_bool_value "$value" 2>/dev/null)"; then
                    persisted_use_zprofile_template="$bool_value"
                else
                    persisted_use_zprofile_template="$value"
                fi
                ;;
            MSE_SELECTED_STEPS)
                legacy_selected_steps="$value"
                ;;
            MSE_DEFAULT_BRANCH)
                persisted_default_branch="$value"
                ;;
            MSE_REGION)
                persisted_region="$value"
                ;;
            MSE_PROXY_MODE)
                persisted_proxy_mode="$value"
                ;;
            MSE_PROXY_PORT)
                persisted_proxy_port="$value"
                ;;
            MSE_STEP_*)
                step="$(step_from_env_key "$key" 2>/dev/null || true)"
                if [ -n "$step" ]; then
                    if bool_value="$(normalize_bool_value "$value" 2>/dev/null)"; then
                        if [ "$bool_value" -eq 1 ]; then
                            persisted_selected_steps="${persisted_selected_steps:+$persisted_selected_steps }$step"
                        fi
                    else
                        log_warn "invalid $key in $(fmt_path "$METADATA_FILE"), expected true or false"
                    fi
                fi
                ;;
        esac
    done < "$METADATA_FILE"

    case "$persisted_git_method" in
        https|ssh) ;;
        *)
            log_warn "invalid MSE_GIT_METHOD in $(fmt_path "$METADATA_FILE"), falling back to https"
            persisted_git_method="https"
            ;;
    esac

    case "$persisted_deploy_mode" in
        fast|interactive) ;;
        *)
            log_warn "invalid MSE_DEPLOY_MODE in $(fmt_path "$METADATA_FILE"), falling back to fast"
            persisted_deploy_mode="fast"
            ;;
    esac

    case "$persisted_region" in
        china|global) ;;
        *)
            log_warn "invalid MSE_REGION in $(fmt_path "$METADATA_FILE"), falling back to china"
            persisted_region="china"
            ;;
    esac

    case "$persisted_proxy_mode" in
        clash|direct-egress) ;;
        *)
            log_warn "invalid MSE_PROXY_MODE in $(fmt_path "$METADATA_FILE"), falling back to clash"
            persisted_proxy_mode="clash"
            ;;
    esac

    case "$persisted_proxy_port" in
        ''|*[!0-9]*)
            log_warn "invalid MSE_PROXY_PORT in $(fmt_path "$METADATA_FILE"), falling back to 8234"
            persisted_proxy_port="8234"
            ;;
    esac

    case "$persisted_use_zprofile_template" in
        0|1) ;;
        *)
            log_warn "invalid MSE_USE_ZPROFILE_TEMPLATE in $(fmt_path "$METADATA_FILE"), falling back to 0"
            persisted_use_zprofile_template=0
            ;;
    esac

    if [ -z "$persisted_selected_steps" ] && [ -n "$legacy_selected_steps" ]; then
        persisted_selected_steps="$legacy_selected_steps"
    fi

    persisted_selected_steps="$(filter_known_steps "$persisted_selected_steps")"
}

persist_deploy_settings() {
    local current_branch=""
    local step=""
    local enabled=0

    current_branch="$(detect_current_branch)"

    cat > "$METADATA_FILE" <<EOF
# MSE install preferences
# This file is written by a successful 'mse deploy'.
# 'mse update' reads it and reuses the same deploy behavior by default.
# You can edit it by hand.
#
# Allowed values:
#   MSE_GIT_METHOD=https|ssh
#   MSE_DEPLOY_MODE=fast|interactive
#   MSE_REGION=china|global
#   MSE_PROXY_MODE=clash|direct-egress
#   MSE_PROXY_PORT=<number>
#   MSE_USE_ZPROFILE_TEMPLATE=true|false
#   MSE_STEP_<NAME>=true|false
#
# Change any MSE_STEP_<NAME> line directly if you want to enable or disable
# an optional step without entering interactive mode again.
# You can also rerun: mse deploy --interactive

MSE_GIT_METHOD='$git_method'
MSE_DEPLOY_MODE='$deploy_mode'
MSE_DEFAULT_BRANCH='$current_branch'
MSE_REGION='$region'
MSE_PROXY_MODE='$proxy_mode'
MSE_PROXY_PORT='$proxy_port'
MSE_USE_ZPROFILE_TEMPLATE='$(bool_string "$use_zprofile_template")'
EOF

    for step in $AVAILABLE_STEPS; do
        enabled=0
        if step_selected "$step"; then
            enabled=1
        fi
        printf "%s='%s'\n" "$(step_env_key "$step")" "$(bool_string "$enabled")" >> "$METADATA_FILE"
    done

    log_ok "saved deploy preferences: $(fmt_path "$METADATA_FILE")"
}

print_selected_steps() {
    local step
    print_section "selected steps"
    if [ -z "$SELECTED_STEPS" ]; then
        log_warn "no optional steps selected"
        return 0
    fi
    for step in $AVAILABLE_STEPS; do
        if ! step_supported_on_platform "$step"; then
            continue
        fi
        if step_selected "$step"; then
            printf '  - %-10b %s\n' "$(fmt_step "$step")" "$(describe_step "$step")"
        fi
    done
}

print_deploy_warnings() {
    print_section "paths that may change"
    log_warn "deployment may create, replace, or back up files under your home directory"

    if [ "$platform" != "Windows" ]; then
        print_path_item "$HOME/.zshrc"
        print_path_item "$OH_MY_ZSH_PATH"
        print_path_item "${ZSH_CUSTOM:-$OH_MY_ZSH_PATH/custom}/plugins/zsh-syntax-highlighting"
        print_path_item "${ZSH_CUSTOM:-$OH_MY_ZSH_PATH/custom}/plugins/zsh-autosuggestions"
        print_path_item "$HOME/.cargo"
        print_path_item "$HOME/.rustup"
        print_path_item "$REPO_BIN_EZA_PATH"
        print_path_item "$REPO_BIN_BAT_PATH"
        print_path_item "$REPO_BIN_RG_PATH"
        if step_selected "cluster_proxy_tools"; then
            print_path_item "$AUTOSSH_TARBALL_PATH"
            print_path_item "$AUTOSSH_PREFIX_DIR"
            print_path_item "$REPO_BIN_AUTOSSH_PATH"
            print_path_item "$PROXYCHAINS_PREFIX_DIR"
            print_path_item "$REPO_BIN_PROXYCHAINS4_PATH"
            print_path_item "$REPO_BIN_PROXYCHAINS_PATH"
            print_path_item "$PROXYCHAINS_CONFIG_PATH"
            print_path_item "$CLASH_REPO_PATH"
            if [ "$platform" = "Linux" ]; then
                print_path_item "$REPO_BIN_CLASH_PATH"
            fi
        fi
        print_list_item "default shell for the current user (via chsh)"
    fi
    if step_selected "micromamba"; then
        print_path_item "$CONDA_ENVS/*.yml"
        print_path_item "$REPO_PATH/conda/micromamba-pycharm"
        if [ "$platform" != "Windows" ]; then
            print_path_item "$ROOT_PATH/bin/micromamba"
        fi
    fi
    if step_selected "condarc"; then
        print_path_item "$HOME/.condarc"
    fi
    if step_selected "pip"; then
        print_path_item "$HOME/.pip/pip.conf"
    fi
    if step_selected "vim"; then
        print_path_item "$HOME/.vim"
        print_path_item "$HOME/.vimrc"
    fi
    if step_selected "nvim"; then
        print_path_item "$HOME/.config/nvim"
        print_path_item "$HOME/.cache/nvim"
        print_path_item "$HOME/.local/share/nvim"
        print_path_item "$HOME/.local/state/nvim"
    fi
    if step_selected "jcat"; then
        print_path_item "$BIN_PATH/jcat"
    fi
    if step_selected "wd"; then
        print_path_item "$HOME/.Wudao-dict"
        print_path_item "$BIN_PATH/wd"
    fi
    if step_selected "powershell"; then
        print_path_item "$HOME/Documents/PowerShell/Microsoft.PowerShell_profile.ps1"
    fi
    if [ "$use_zprofile_template" -eq 1 ] && [ "$platform" != "Windows" ]; then
        print_path_item "$HOME/.zprofile"
        print_path_item "$HOME/.zprofile_bak"
    fi

    log_info "linked target files are backed up to *_bak when possible; repo bin is preserved"
}

backup_existing_path() {
    local target="$1"
    local backup_path="${target}_bak"

    if [ -L "$target" ]; then
        /bin/rm -rf "$target" 2>/dev/null
    elif [ -e "$target" ]; then
        /bin/rm -rf "$backup_path" 2>/dev/null
        mv "$target" "$backup_path"
    fi
}

backup_and_link() {
    local source_path="$1"
    local target_path="$2"

    backup_existing_path "$target_path"
    ln -s "$source_path" "$target_path"
}

backup_and_link_windows_native() {
    local source_path="$1"
    local target_path="$2"
    local source_windows=""
    local target_windows=""

    require_cmd pwsh
    require_cmd cygpath

    backup_existing_path "$target_path"

    source_windows="$(cygpath -aw "$source_path")" || fail "failed to convert source path for Windows symlink: $source_path"
    target_windows="$(cygpath -aw "$target_path")" || fail "failed to convert target path for Windows symlink: $target_path"

    pwsh -NoProfile -Command "\$source = '$source_windows'; \$target = '$target_windows'; New-Item -ItemType SymbolicLink -Path \$target -Target \$source -Force | Out-Null" \
        || fail "failed to create Windows symbolic link: $target_path -> $source_path"
}

force_link_windows_native() {
    local source_path="$1"
    local target_path="$2"
    local source_windows=""
    local target_windows=""

    require_cmd pwsh
    require_cmd cygpath

    /bin/rm -rf "$target_path" 2>/dev/null

    source_windows="$(cygpath -aw "$source_path")" || fail "failed to convert source path for Windows symlink: $source_path"
    target_windows="$(cygpath -aw "$target_path")" || fail "failed to convert target path for Windows symlink: $target_path"

    pwsh -NoProfile -Command "\$source = '$source_windows'; \$target = '$target_windows'; New-Item -ItemType SymbolicLink -Path \$target -Target \$source -Force | Out-Null" \
        || fail "failed to create Windows symbolic link: $target_path -> $source_path"
}

force_link() {
    local source_path="$1"
    local target_path="$2"

    /bin/rm -rf "$target_path" 2>/dev/null
    ln -s "$source_path" "$target_path"
}

resolve_windows_powershell_profile_dir() {
    local documents_windows=""
    local documents_unix=""

    require_cmd pwsh
    require_cmd cygpath

    documents_windows="$(pwsh -NoProfile -Command "[Environment]::GetFolderPath('MyDocuments')" | tr -d '\r')" || return 1
    [ -n "$documents_windows" ] || return 1

    documents_unix="$(cygpath -u "$documents_windows")" || return 1
    printf '%s/PowerShell\n' "$documents_unix"
}

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || fail "Seems the command '$1' is not installed on your system, please install it first."
}

install_python_packages_if_available() {
    local installer_name=""

    if command -v pip >/dev/null 2>&1; then
        installer_name="pip"
        pip install "$@" || log_warn "failed to install Python packages with $installer_name: $*"
        return 0
    fi

    if command -v pip3 >/dev/null 2>&1; then
        installer_name="pip3"
        pip3 install "$@" || log_warn "failed to install Python packages with $installer_name: $*"
        return 0
    fi

    if command -v python >/dev/null 2>&1; then
        installer_name="python -m pip"
        python -m pip install "$@" || log_warn "failed to install Python packages with $installer_name: $*"
        return 0
    fi

    if command -v python3 >/dev/null 2>&1; then
        installer_name="python3 -m pip"
        python3 -m pip install "$@" || log_warn "failed to install Python packages with $installer_name: $*"
        return 0
    fi

    if command -v py >/dev/null 2>&1; then
        installer_name="py -m pip"
        py -m pip install "$@" || log_warn "failed to install Python packages with $installer_name: $*"
        return 0
    fi

    log_warn "skip Python package install because pip/python was not found in PATH: $*"
    return 0
}

