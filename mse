#!/usr/bin/env bash

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
REPO_PATH="$SCRIPT_DIR"
BIN_PATH="$REPO_PATH/bin"
CONDA_ENVS="$REPO_PATH/conda_local_env_settings"
METADATA_FILE="$REPO_PATH/.mse-install.env"
GLOBAL_WRAPPER_PATH="$HOME/.local/bin/mse"
REPO_BIN_MSE_PATH="$BIN_PATH/mse"
ZPROFILE_TEMPLATE_PATH="$REPO_PATH/zsh/zprofile_hermanzhaozzzz_demo"
DEFAULT_REPO_URL="https://github.com/hermanzhaozzzz/.my_shell_envs.git"
DEFAULT_REPO_SSH_URL="git@github.com:hermanzhaozzzz/.my_shell_envs.git"
DEFAULT_BRANCH="main"
DEFAULT_ARCHIVE_URL="https://codeload.github.com/hermanzhaozzzz/.my_shell_envs/tar.gz/refs/heads/${DEFAULT_BRANCH}"
AVAILABLE_STEPS="micromamba condarc pip vim nvim jcat wd powershell"
OH_MY_ZSH_PATH="$HOME/.oh-my-zsh"
OH_MY_ZSH_INSTALL_URL="https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh"
ZSH_HIGHLIGHTING_REPO_PATH="zsh-users/zsh-syntax-highlighting.git"
ZSH_AUTOSUGGESTIONS_REPO_PATH="zsh-users/zsh-autosuggestions"

git_method="https"
deploy_mode="fast"
list_steps=0
SELECTED_STEPS=""
use_zprofile_template=0

print_root_usage() {
    cat <<'EOF'
Usage:
  ./mse <command> [options]
  ./mse -h|--help

Commands:
  deploy    Deploy environment modules
  update    Update source code and redeploy
  help      Show this help message

Examples:
  ./mse deploy
  ./mse deploy --ssh --interactive
  ./mse deploy --use-zprofile-template
  ./mse update
  ./mse update --interactive
EOF
}

print_deploy_usage() {
    cat <<'EOF'
Usage:
  ./mse deploy [--ssh|--https] [--interactive|--fast] [--use-zprofile-template]
  ./mse deploy --git-method https --mode fast
  ./mse deploy --list-steps
  ./mse deploy -h|--help

Defaults:
  git method: https
  deploy mode: fast

Mandatory base setup on non-Windows:
  requires zsh in PATH, then installs Oh My Zsh + required plugins + ~/.zshrc + default shell switch

Examples:
  ./mse deploy
  ./mse deploy --ssh
  ./mse deploy --interactive
  ./mse deploy --ssh --interactive
  ./mse deploy --interactive --use-zprofile-template
EOF
}

print_update_usage() {
    cat <<'EOF'
Usage:
  ./mse update [--ssh|--https] [--interactive|--fast] [--use-zprofile-template]
  ./mse update --git-method https --mode fast
  ./mse update -h|--help

Behavior:
  update source code first, then run deploy with the same flags

Examples:
  ./mse update
  ./mse update --interactive
  ./mse update --ssh --interactive
  ./mse update --interactive --use-zprofile-template
EOF
}

fail() {
    printf '%s %s\n' "$(badge "$COLOR_RED" "ERR")" "$*" >&2
    exit 1
}

setup_colors() {
    local esc
    esc="$(printf '\033')"

    COLOR_RESET=""
    COLOR_BOLD=""
    COLOR_BLUE=""
    COLOR_CYAN=""
    COLOR_GREEN=""
    COLOR_YELLOW=""
    COLOR_RED=""
    COLOR_MAGENTA=""
    COLOR_DIM=""

    if [ -t 1 ] && [ "${TERM:-}" != "dumb" ]; then
        COLOR_RESET="${esc}[0m"
        COLOR_BOLD="${esc}[1m"
        COLOR_DIM="${esc}[2m"
        COLOR_BLUE="${esc}[34m"
        COLOR_CYAN="${esc}[36m"
        COLOR_GREEN="${esc}[32m"
        COLOR_YELLOW="${esc}[33m"
        COLOR_RED="${esc}[31m"
        COLOR_MAGENTA="${esc}[35m"
    fi
}

badge() {
    local color="$1"
    local text="$2"
    printf '%s[%s]%s' "${color}${COLOR_BOLD}" "$text" "$COLOR_RESET"
}

fmt_path() {
    printf '%s%s%s' "${COLOR_CYAN}" "$1" "$COLOR_RESET"
}

fmt_key() {
    printf '%s%s%s' "${COLOR_MAGENTA}${COLOR_BOLD}" "$1" "$COLOR_RESET"
}

fmt_step() {
    printf '%s%s%s' "${COLOR_MAGENTA}${COLOR_BOLD}" "$1" "$COLOR_RESET"
}

log_info() {
    printf '%s %s\n' "$(badge "$COLOR_BLUE" "INFO")" "$*"
}

log_ok() {
    printf '%s %s\n' "$(badge "$COLOR_GREEN" " OK ")" "$*"
}

log_warn() {
    printf '%s %s\n' "$(badge "$COLOR_YELLOW" "WARN")" "$*"
}

print_path_item() {
    printf '  - %s\n' "$(fmt_path "$1")"
}

print_list_item() {
    printf '  - %s\n' "$1"
}

print_kv() {
    printf '  %s %s\n' "$(fmt_key "$1")" "$2"
}

can_prompt_user() {
    [ -t 0 ] && [ -t 1 ]
}

detect_current_shell_name() {
    local shell_name=""

    if [ -n "${SHELL:-}" ]; then
        shell_name="${SHELL##*/}"
    fi

    if [ -z "$shell_name" ] || [ "$shell_name" = "sh" ]; then
        shell_name="$(ps -p "$PPID" -o comm= 2>/dev/null | awk '{print $1}' | sed 's#.*/##')"
    fi

    printf '%s\n' "$shell_name"
}

detect_shell_rc_path() {
    case "$1" in
        bash) printf '%s\n' "$HOME/.bashrc" ;;
        zsh) printf '%s\n' "$HOME/.zshrc" ;;
        *) return 1 ;;
    esac
}

write_zsh_handoff_block() {
    local rc_path="$1"
    local zsh_path="$2"
    local tmp_file
    local backup_path=""

    mkdir -p "$(dirname "$rc_path")"

    if [ -f "$rc_path" ]; then
        backup_path="${rc_path}.mse.bak.$(date +%Y%m%d_%H%M%S)"
        cp -f "$rc_path" "$backup_path" 2>/dev/null || true
        log_info "backed up existing shell config to $(fmt_path "$backup_path")"
    fi

    tmp_file="$(mktemp "${TMPDIR:-/tmp}/mse-shell.XXXXXX")" || fail "failed to create temporary file for shell handoff config"

    if [ -f "$rc_path" ]; then
        awk '
            BEGIN { skip=0 }
            /^# >>> MSE auto-enter zsh >>>$/ { skip=1; next }
            /^# <<< MSE auto-enter zsh <<<$/{ skip=0; next }
            skip == 0 { print }
        ' "$rc_path" > "$tmp_file"
    else
        : > "$tmp_file"
    fi

    cat >>"$tmp_file" <<EOF
# >>> MSE auto-enter zsh >>>
if [ -x "$zsh_path" ] && [ -z "\${MSE_AUTO_ENTER_ZSH:-}" ]; then
    export SHELL="$zsh_path"
    export MSE_AUTO_ENTER_ZSH=1
    exec "$zsh_path" -l
fi
# <<< MSE auto-enter zsh <<<
EOF

    mv "$tmp_file" "$rc_path" || fail "failed to update shell config at $rc_path"
    export SHELL="$zsh_path"
    log_ok "current shell handoff added to $(fmt_path "$rc_path")"
}

offer_zsh_handoff_setup() {
    local zsh_path="$1"
    local current_shell_name="$2"
    local rc_path=""
    local answer=""

    if [ "$current_shell_name" = "zsh" ]; then
        log_info "current shell already looks like zsh; skipping shell config injection"
        return 0
    fi

    if ! can_prompt_user; then
        log_warn "cannot prompt in this session; skipping shell config injection"
        log_warn "recommended: add an auto-enter zsh block to your ${current_shell_name:-current shell} config manually"
        return 0
    fi

    rc_path="$(detect_shell_rc_path "$current_shell_name" 2>/dev/null || true)"

    print_section "zsh handoff setup"
    log_warn "this environment is designed to run inside zsh"

    if [ -n "$rc_path" ]; then
        print_list_item "your current login shell appears to be: $current_shell_name"
        print_list_item "MSE can append an auto-enter zsh block to: $rc_path"
        print_list_item "this makes future interactive $current_shell_name sessions jump into zsh automatically"

        while :; do
            printf '%s add zsh handoff to %s? [y/N]: ' "$(badge "$COLOR_BLUE" "ASK")" "$(fmt_path "$rc_path")"
            read answer || break
            case "$answer" in
                y|Y|yes|YES)
                    write_zsh_handoff_block "$rc_path" "$zsh_path"
                    return 0
                    ;;
                n|N|no|NO|"")
                    log_warn "skipping shell config injection"
                    print_list_item "recommended: rerun deploy later and retry chsh, or add an auto-enter zsh block to $rc_path yourself"
                    return 0
                    ;;
            esac
        done
    else
        log_warn "could not map current shell '$current_shell_name' to a known rc file"
        print_list_item "recommended: configure your login shell to start zsh automatically, then rerun deploy if needed"
    fi

    return 0
}

print_section() {
    printf '\n%s==>%s %b\n' "${COLOR_BLUE}${COLOR_BOLD}" "${COLOR_RESET}" "$1"
}

describe_step() {
    case "$1" in
        micromamba) echo "install micromamba and link conda env yml files" ;;
        condarc) echo "link ~/.condarc to the repo config" ;;
        pip) echo "link pip.conf" ;;
        vim) echo "clone or update vim-for-coding" ;;
        nvim) echo "clone or update MyLazyVim" ;;
        jcat) echo "build and link jcat" ;;
        wd) echo "clone or update Wudao-dict" ;;
        powershell) echo "set the PowerShell profile on Windows" ;;
        *) echo "custom step" ;;
    esac
}

append_selected_step() {
    local step="$1"
    if [ -z "$SELECTED_STEPS" ]; then
        SELECTED_STEPS="$step"
    else
        SELECTED_STEPS="$SELECTED_STEPS $step"
    fi
}

step_selected() {
    local target="$1"
    local step
    for step in $SELECTED_STEPS; do
        if [ "$step" = "$target" ]; then
            return 0
        fi
    done
    return 1
}

step_supported_on_platform() {
    case "$1" in
        powershell)
            [ "$platform" = "Windows" ]
            ;;
        jcat)
            [ "$platform" != "Windows" ]
            ;;
        *)
            return 0
            ;;
    esac
}

setup_colors

print_available_steps() {
    local step
    print_section "available steps"
    print_kv "base" "requires zsh in PATH, then configures Oh My Zsh, required plugins, ~/.zshrc, default shell switch"
    for step in $AVAILABLE_STEPS; do
        if ! step_supported_on_platform "$step"; then
            continue
        fi
        printf '  - %-10b %s\n' "$(fmt_step "$step")" "$(describe_step "$step")"
    done
}

print_selected_steps() {
    local step
    print_section "selected steps"
    if [ -z "$SELECTED_STEPS" ]; then
        log_warn "no optional steps selected"
        return 0
    fi
    for step in $AVAILABLE_STEPS; do
        if ! step_supported_on_platform "$step"; then
            continue
        fi
        if step_selected "$step"; then
            printf '  - %-10b %s\n' "$(fmt_step "$step")" "$(describe_step "$step")"
        fi
    done
}

print_deploy_warnings() {
    print_section "paths that may change"
    log_warn "deployment may create, replace, or back up files under your home directory"

    if [ "$platform" != "Windows" ]; then
        print_path_item "$HOME/.zshrc"
        print_path_item "$OH_MY_ZSH_PATH"
        print_path_item "${ZSH_CUSTOM:-$OH_MY_ZSH_PATH/custom}/plugins/zsh-syntax-highlighting"
        print_path_item "${ZSH_CUSTOM:-$OH_MY_ZSH_PATH/custom}/plugins/zsh-autosuggestions"
        print_list_item "default shell for the current user (via chsh)"
    fi

    if step_selected "micromamba"; then
        print_path_item "$ROOT_PATH/bin/micromamba"
        print_path_item "$CONDA_ENVS/*.yml"
        print_path_item "$REPO_PATH/conda/micromamba-pycharm"
    fi
    if step_selected "condarc"; then
        print_path_item "$HOME/.condarc"
    fi
    if step_selected "pip"; then
        print_path_item "$HOME/.pip/pip.conf"
    fi
    if step_selected "vim"; then
        print_path_item "$HOME/.vim"
        print_path_item "$HOME/.vimrc"
    fi
    if step_selected "nvim"; then
        print_path_item "$HOME/.config/nvim"
        print_path_item "$HOME/.cache/nvim"
        print_path_item "$HOME/.local/share/nvim"
        print_path_item "$HOME/.local/state/nvim"
    fi
    if step_selected "jcat"; then
        print_path_item "$BIN_PATH/jcat"
    fi
    if step_selected "wd"; then
        print_path_item "$HOME/.Wudao-dict"
        print_path_item "$BIN_PATH/wd"
    fi
    if step_selected "powershell"; then
        print_path_item "/c/Program Files/PowerShell/7/profile.ps1"
    fi
    if [ "$use_zprofile_template" -eq 1 ] && [ "$platform" != "Windows" ]; then
        print_path_item "$HOME/.zprofile"
        print_path_item "$HOME/.zprofile_bak"
    fi

    log_info "existing files are backed up to *_bak or *.backup.* when possible"
}

backup_existing_path() {
    local target="$1"
    local backup_path="${target}_bak"

    if [ -L "$target" ]; then
        /bin/rm -rf "$target" 2>/dev/null
    elif [ -e "$target" ]; then
        /bin/rm -rf "$backup_path" 2>/dev/null
        mv "$target" "$backup_path"
    fi
}

backup_and_link() {
    local source_path="$1"
    local target_path="$2"

    backup_existing_path "$target_path"
    ln -s "$source_path" "$target_path"
}

force_link() {
    local source_path="$1"
    local target_path="$2"

    /bin/rm -rf "$target_path" 2>/dev/null
    ln -s "$source_path" "$target_path"
}

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || fail "Seems the command '$1' is not installed on your system, please install it first."
}

get_zsh_custom_path() {
    printf '%s\n' "${ZSH_CUSTOM:-$OH_MY_ZSH_PATH/custom}"
}

get_clone_url() {
    printf '%s%s\n' "$url_root" "$1"
}

detect_git_repo_url() {
    if [ -d "$REPO_PATH/.git" ]; then
        git -C "$REPO_PATH" remote get-url origin 2>/dev/null && return 0
    fi
    printf '%s\n' "$DEFAULT_REPO_URL"
}

write_install_metadata() {
    local install_mode="$1"
    local repo_url="$2"
    local repo_branch="$3"

    cat >"$METADATA_FILE" <<EOF
INSTALL_MODE="$install_mode"
MSE_REPO_URL="$repo_url"
MSE_DEFAULT_BRANCH="$repo_branch"
EOF
}

load_install_metadata() {
    INSTALL_MODE=""
    MSE_REPO_URL="$DEFAULT_REPO_URL"
    MSE_DEFAULT_BRANCH="$DEFAULT_BRANCH"

    if [ -f "$METADATA_FILE" ]; then
        # shellcheck disable=SC1090
        . "$METADATA_FILE"
    fi

    if [ -d "$REPO_PATH/.git" ]; then
        INSTALL_MODE="git"
        MSE_REPO_URL="$(detect_git_repo_url)"
        MSE_DEFAULT_BRANCH="$DEFAULT_BRANCH"
    elif [ -z "$INSTALL_MODE" ]; then
        INSTALL_MODE="archive"
    fi
}

refresh_git_install_metadata() {
    if [ -d "$REPO_PATH/.git" ]; then
        write_install_metadata "git" "$(detect_git_repo_url)" "$DEFAULT_BRANCH"
    fi
}

install_global_wrapper() {
    local backup_path
    local repo_bin_backup_path

    mkdir -p "$HOME/.local/bin"
    mkdir -p "$BIN_PATH"

    if [ -e "$REPO_BIN_MSE_PATH" ] || [ -L "$REPO_BIN_MSE_PATH" ]; then
        if [ ! -L "$REPO_BIN_MSE_PATH" ]; then
            repo_bin_backup_path="${REPO_BIN_MSE_PATH}.bak.$(date +%Y%m%d_%H%M%S)"
            cp -f "$REPO_BIN_MSE_PATH" "$repo_bin_backup_path" 2>/dev/null || true
        fi
        /bin/rm -f "$REPO_BIN_MSE_PATH"
    fi
    ln -s "$REPO_PATH/mse" "$REPO_BIN_MSE_PATH" || fail "failed to create symlink $REPO_BIN_MSE_PATH -> $REPO_PATH/mse"

    if [ -e "$GLOBAL_WRAPPER_PATH" ] || [ -L "$GLOBAL_WRAPPER_PATH" ]; then
        if [ ! -L "$GLOBAL_WRAPPER_PATH" ]; then
            backup_path="${GLOBAL_WRAPPER_PATH}.bak.$(date +%Y%m%d_%H%M%S)"
            cp -f "$GLOBAL_WRAPPER_PATH" "$backup_path" 2>/dev/null || true
        fi
        /bin/rm -f "$GLOBAL_WRAPPER_PATH"
    fi

    cat >"$GLOBAL_WRAPPER_PATH" <<EOF
#!/usr/bin/env sh
if [ ! -x "$REPO_PATH/mse" ]; then
    echo "mse is not installed at $REPO_PATH" >&2
    exit 1
fi
exec "$REPO_PATH/mse" "\$@"
EOF
    chmod +x "$GLOBAL_WRAPPER_PATH"

    case ":$PATH:" in
        *":$HOME/.local/bin:"*)
            ;;
        *)
            log_warn "add \$HOME/.local/bin to PATH if you want the wrapper command 'mse' globally"
            ;;
    esac

    log_ok "repo bin entry created: $(fmt_path "$REPO_BIN_MSE_PATH") -> $(fmt_path "$REPO_PATH/mse")"
}

cleanup_legacy_spyder() {
    local spyder_path="$HOME/.spyder-py3"
    local target_path=""

    if [ -L "$spyder_path" ]; then
        target_path="$(readlink "$spyder_path" 2>/dev/null || true)"
        case "$target_path" in
            "$REPO_PATH"/spyder|"$REPO_PATH"/spyder/*)
                if /bin/rm -f "$spyder_path"; then
                    log_ok "removed legacy Spyder symlink: $(fmt_path "$spyder_path")"
                else
                    log_warn "failed to remove legacy Spyder symlink: $(fmt_path "$spyder_path")"
                fi
                ;;
        esac
    fi
}

detect_platform_settings() {
    local raw_platform
    local arch

    platform=""
    platform_family=""
    MICROMAMBA_URL=""
    ROOT_PATH=""

    raw_platform="$(uname)"
    raw_platform="${raw_platform%%_*}"

    if [ "$raw_platform" = "Linux" ]; then
        platform="Linux"
        MICROMAMBA_URL="https://micro.mamba.pm/api/micromamba/linux-64/latest"
        ROOT_PATH="$HOME/0.apps/micromamba"
    elif [ "$raw_platform" = "Darwin" ]; then
        arch="$(uname -m)"
        if [ "$arch" = "x86_64" ] || [ "$arch" = "i386" ]; then
            platform="MacOS/x86_64"
            MICROMAMBA_URL="https://micro.mamba.pm/api/micromamba/osx-64/latest"
            ROOT_PATH="$HOME/micromamba"
        elif [ "$arch" = "arm64" ] || [ "$arch" = "arm" ]; then
            platform="MacOS/arm64"
            MICROMAMBA_URL="https://micro.mamba.pm/api/micromamba/osx-arm64/latest"
            ROOT_PATH="$HOME/micromamba"
        else
            fail "unsupported MacOS arch: $arch"
        fi
    elif [ "$raw_platform" = "MINGW64" ] || [ "$raw_platform" = "MSYS" ] || [ "$raw_platform" = "CYGWIN" ]; then
        platform="Windows"
    else
        fail "unsupported OS: $raw_platform"
    fi

    platform_family="${platform%%/*}"
}

choose_steps() {
    local step
    local answer
    local step_no=0

    if [ "$deploy_mode" = "fast" ]; then
        for step in $AVAILABLE_STEPS; do
            if step_supported_on_platform "$step"; then
                append_selected_step "$step"
            fi
        done
        log_info "fast mode selected all supported optional steps automatically"
        return 0
    fi

    print_section "interactive step selection"
    log_info "press y to enable a step, press Enter to skip it"
    for step in $AVAILABLE_STEPS; do
        if ! step_supported_on_platform "$step"; then
            continue
        fi
        step_no=$((step_no + 1))
        printf '  %s %-2s %-12b %s [y/N]: ' "$(badge "$COLOR_BLUE" "STEP")" "$step_no" "$(fmt_step "$step")" "$(describe_step "$step")"
        read answer
        case "$answer" in
            y|Y|yes|YES)
                append_selected_step "$step"
                log_ok "enabled step: $step"
                ;;
            *)
                log_warn "skipped step: $step"
                ;;
        esac
    done
}

run_step() {
    local step="$1"
    local function_name="$2"

    if ! step_supported_on_platform "$step"; then
        return 0
    fi

    if step_selected "$step"; then
        print_section "step $(fmt_step "$step")"
        "$function_name"
        log_ok "step completed: $step"
    else
        log_warn "skip step: $step"
    fi
}

parse_deploy_args() {
    git_method="https"
    deploy_mode="fast"
    list_steps=0
    use_zprofile_template=0

    while [ $# -gt 0 ]; do
        case "$1" in
            --https)
                git_method="https"
                ;;
            --ssh)
                git_method="ssh"
                ;;
            --fast)
                deploy_mode="fast"
                ;;
            --interactive)
                deploy_mode="interactive"
                ;;
            --use-zprofile-template)
                use_zprofile_template=1
                ;;
            --git-method)
                shift
                [ $# -gt 0 ] || fail "--git-method requires a value: https or ssh"
                case "$1" in
                    https|ssh)
                        git_method="$1"
                        ;;
                    *)
                        fail "unsupported git method: $1"
                        ;;
                esac
                ;;
            --mode)
                shift
                [ $# -gt 0 ] || fail "--mode requires a value: fast or interactive"
                case "$1" in
                    fast|interactive)
                        deploy_mode="$1"
                        ;;
                    *)
                        fail "unsupported deploy mode: $1"
                        ;;
                esac
                ;;
            --list-steps)
                list_steps=1
                ;;
            -h|--help|help)
                print_deploy_usage
                exit 0
                ;;
            *)
                fail "unknown argument for 'mse deploy': $1. Run './mse deploy -h' for help."
                ;;
        esac
        shift
    done
}

parse_update_args() {
    local opt_name

    UPDATE_DEPLOY_ARGS=()

    while [ $# -gt 0 ]; do
        case "$1" in
            --https|--ssh|--fast|--interactive|--list-steps)
                UPDATE_DEPLOY_ARGS+=("$1")
                ;;
            --use-zprofile-template)
                UPDATE_DEPLOY_ARGS+=("$1")
                ;;
            --git-method|--mode)
                opt_name="$1"
                UPDATE_DEPLOY_ARGS+=("$1")
                shift
                [ $# -gt 0 ] || fail "$opt_name requires a value"
                UPDATE_DEPLOY_ARGS+=("$1")
                ;;
            -h|--help|help)
                print_update_usage
                exit 0
                ;;
            *)
                fail "unknown argument for 'mse update': $1. Run './mse update -h' for help."
                ;;
        esac
        shift
    done
}

download_source_archive() {
    local archive_file="$1"

    require_cmd curl
    require_cmd tar

    curl -fsSL "$DEFAULT_ARCHIVE_URL" -o "$archive_file" || fail "failed to download source archive from GitHub"
}

extract_source_dir() {
    local archive_file="$1"
    local extract_root="$2"
    local source_dir

    mkdir -p "$extract_root"
    tar -xzf "$archive_file" -C "$extract_root" || fail "failed to extract source archive"
    source_dir="$(find "$extract_root" -mindepth 1 -maxdepth 1 -type d | head -n 1)"
    [ -n "$source_dir" ] || fail "cannot find extracted source directory"
    printf '%s\n' "$source_dir"
}

update_from_git() {
    local repo_url

    if [ -n "$(git -C "$REPO_PATH" status --porcelain)" ]; then
        fail "git working tree is not clean. Please commit, stash, or remove local changes before running './mse update'."
    fi

    git -C "$REPO_PATH" fetch || fail "git fetch failed"
    git -C "$REPO_PATH" pull --rebase || fail "git pull --rebase failed"

    repo_url="$(detect_git_repo_url)"
    write_install_metadata "git" "$repo_url" "$DEFAULT_BRANCH"
    install_global_wrapper

    exec "$REPO_PATH/mse" deploy "${UPDATE_DEPLOY_ARGS[@]}"
}

update_from_archive() {
    local tmp_root
    local archive_file
    local extract_root
    local source_dir
    local backup_path

    tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/mse-update.XXXXXX")" || fail "failed to create temporary directory"
    archive_file="$tmp_root/source.tar.gz"
    extract_root="$tmp_root/extracted"
    backup_path="${REPO_PATH}.backup.$(date +%Y%m%d_%H%M%S)"

    download_source_archive "$archive_file"
    source_dir="$(extract_source_dir "$archive_file" "$extract_root")"

    case "$(pwd)" in
        "$REPO_PATH"|"$REPO_PATH"/*)
            cd "$HOME" || fail "failed to leave repo directory before update"
            ;;
    esac

    cp -R "$REPO_PATH" "$backup_path" || fail "failed to back up current installation to $backup_path"
    find "$REPO_PATH" -mindepth 1 -maxdepth 1 -exec /bin/rm -rf {} + || fail "failed to clean current installation directory"
    cp -R "$source_dir/." "$REPO_PATH/" || fail "failed to copy updated files into $REPO_PATH"

    write_install_metadata "archive" "$DEFAULT_REPO_URL" "$DEFAULT_BRANCH"
    install_global_wrapper

    exec "$REPO_PATH/mse" deploy "${UPDATE_DEPLOY_ARGS[@]}"
}

apply_zprofile_template() {
    if [ "$platform" = "Windows" ]; then
        log_warn "skip zprofile template on platform: $platform"
        return 0
    fi

    print_section "apply personal zprofile template"
    /bin/rm "$HOME/.zprofile_bak" 2>/dev/null
    mv "$HOME/.zprofile" "$HOME/.zprofile_bak" 2>/dev/null || true
    /bin/rm -f "$HOME/.zprofile" 2>/dev/null
    ln -s "$ZPROFILE_TEMPLATE_PATH" "$HOME/.zprofile" || fail "failed to link $HOME/.zprofile to $ZPROFILE_TEMPLATE_PATH"
    log_ok "zprofile template linked: $(fmt_path "$HOME/.zprofile") -> $(fmt_path "$ZPROFILE_TEMPLATE_PATH")"
}

ensure_zsh_installed() {
    if [ "$platform" = "Windows" ]; then
        return 0
    fi

    print_section "ensure zsh is installed"
    if command -v zsh >/dev/null 2>&1; then
        log_ok "zsh found at $(fmt_path "$(command -v zsh)")"
        return 0
    fi

    fail "zsh is required but was not found in PATH. Please install zsh manually for your system, then rerun ./mse deploy"
}

ensure_oh_my_zsh_installed() {
    if [ "$platform" = "Windows" ]; then
        return 0
    fi

    print_section "ensure Oh My Zsh is installed"
    if [ -d "$OH_MY_ZSH_PATH" ]; then
        log_ok "Oh My Zsh found at $(fmt_path "$OH_MY_ZSH_PATH")"
        return 0
    fi

    require_cmd git
    require_cmd curl
    log_info "Oh My Zsh not found, installing"
    RUNZSH=no CHSH=no KEEP_ZSHRC=yes /bin/sh -c "$(curl -fsSL "$OH_MY_ZSH_INSTALL_URL")" || fail "failed to install Oh My Zsh"
    [ -d "$OH_MY_ZSH_PATH" ] || fail "Oh My Zsh installation completed but $OH_MY_ZSH_PATH was not created"
    log_ok "Oh My Zsh installed at $(fmt_path "$OH_MY_ZSH_PATH")"
}

sync_zsh_plugin_repo() {
    local plugin_dir="$1"
    local plugin_url="$2"

    if [ -d "$plugin_dir/.git" ]; then
        git -C "$plugin_dir" fetch || fail "failed to fetch plugin updates for $plugin_dir"
        git -C "$plugin_dir" pull --ff-only || fail "failed to update plugin at $plugin_dir"
        log_ok "plugin updated: $(fmt_path "$plugin_dir")"
    elif [ -d "$plugin_dir" ]; then
        log_info "plugin directory exists, keeping current contents: $(fmt_path "$plugin_dir")"
    else
        git clone "$plugin_url" "$plugin_dir" || fail "failed to clone plugin from $plugin_url"
        log_ok "plugin installed: $(fmt_path "$plugin_dir")"
    fi
}

ensure_zsh_plugins_installed() {
    local custom_path

    if [ "$platform" = "Windows" ]; then
        return 0
    fi

    print_section "ensure required zsh plugins are installed"
    require_cmd git
    custom_path="$(get_zsh_custom_path)"
    mkdir -p "$custom_path/plugins"

    sync_zsh_plugin_repo "$custom_path/plugins/zsh-syntax-highlighting" "$(get_clone_url "$ZSH_HIGHLIGHTING_REPO_PATH")"
    sync_zsh_plugin_repo "$custom_path/plugins/zsh-autosuggestions" "$(get_clone_url "$ZSH_AUTOSUGGESTIONS_REPO_PATH")"

    log_info "standard Oh My Zsh plugins required by this repo: git, z"
    log_info "custom plugin root: $(fmt_path "$custom_path/plugins")"
}

ensure_zshrc_linked() {
    if [ "$platform" = "Windows" ]; then
        return 0
    fi

    print_section "ensure zshrc is linked"
    backup_and_link "$REPO_PATH/zsh/zshrc" "$HOME/.zshrc"
    log_info "repo zshrc: $(fmt_path "$REPO_PATH/zsh/zshrc")"
    log_ok "$(fmt_path "$HOME/.zshrc") linked successfully"
}

ensure_default_shell_is_zsh() {
    local zsh_path
    local current_shell="${SHELL:-}"
    local current_shell_name=""
    local answer=""

    if [ "$platform" = "Windows" ]; then
        return 0
    fi

    print_section "ensure default shell is zsh"
    zsh_path="$(command -v zsh)" || fail "zsh is required before switching the default shell"

    if [ "${current_shell##*/}" = "zsh" ]; then
        log_ok "default shell already looks like zsh: $(fmt_path "$current_shell")"
        return 0
    fi

    current_shell_name="$(detect_current_shell_name)"

    if ! command -v chsh >/dev/null 2>&1; then
        log_warn "chsh is not available on this system; skipping default-shell change"
        offer_zsh_handoff_setup "$zsh_path" "$current_shell_name"
        return 0
    fi

    while :; do
        if chsh -s "$zsh_path"; then
            export SHELL="$zsh_path"
            log_ok "default shell switched to zsh: $(fmt_path "$zsh_path")"
            return 0
        fi

        log_warn "failed to switch the default shell to zsh"

        if ! can_prompt_user; then
            offer_zsh_handoff_setup "$zsh_path" "$current_shell_name"
            return 0
        fi

        print_section "default shell change failed"
        print_list_item "option 1: retry and enter your password again"
        print_list_item "option 2: skip chsh and continue deployment"

        while :; do
            printf '%s choose [r]etry or [s]kip: ' "$(badge "$COLOR_BLUE" "ASK")"
            read answer || break
            case "$answer" in
                r|R|retry|RETRY)
                    break
                    ;;
                s|S|skip|SKIP)
                    log_warn "continuing without changing the default shell"
                    offer_zsh_handoff_setup "$zsh_path" "$current_shell_name"
                    return 0
                    ;;
            esac
        done
    done
}

ensure_non_windows_zsh_core() {
    if [ "$platform" = "Windows" ]; then
        return 0
    fi

    ensure_zsh_installed
    ensure_oh_my_zsh_installed
    ensure_zsh_plugins_installed
    ensure_zshrc_linked
    ensure_default_shell_is_zsh
}

step_micromamba() {
    local yml
    local found_any=0

    if [ "$platform" = "Windows" ]; then
        log_warn "skip micromamba on Windows"
        return 0
    fi

    log_info "prepare micromamba and conda env config files"

    if [ ! -x "$ROOT_PATH/bin/micromamba" ]; then
        log_info "micromamba not found at $(fmt_path "$ROOT_PATH/bin/micromamba"), starting install"
        require_cmd bzip2
        require_cmd curl
        require_cmd tar

        mkdir -p "$ROOT_PATH"
        (
            cd "$ROOT_PATH" || exit 1
            curl -Ls "$MICROMAMBA_URL" | tar -xvj bin/micromamba
        ) || fail "micromamba installation failed"
    else
        log_ok "micromamba already exists at $(fmt_path "$ROOT_PATH/bin/micromamba")"
    fi

    if [ ! -d "$REPO_PATH/conda/micromamba-pycharm/.git" ]; then
        git clone "${url_root}jonashaag/micromamba-pycharm.git" "$REPO_PATH/conda/micromamba-pycharm"
    else
        log_ok "micromamba-pycharm exists at $(fmt_path "$REPO_PATH/conda/micromamba-pycharm")"
    fi

    log_info "link env yml files for platform $(fmt_step "$platform")"
    mkdir -p "$CONDA_ENVS"

    for yml in "$REPO_PATH"/conda/"$platform"/*.yml; do
        [ -e "$yml" ] || continue
        found_any=1
        force_link "$yml" "$CONDA_ENVS/$(basename "$yml")"
    done

    if [ "$found_any" -eq 0 ]; then
        log_warn "no env.yml files found for platform: $platform"
    fi

    log_ok "conda env config directory ready: $(fmt_path "$CONDA_ENVS")"
    log_ok "micromamba is ready to act as conda / mamba"
}

step_condarc() {
    log_info "link condarc"
    backup_and_link "$REPO_PATH/conda/condarc" "$HOME/.condarc"
    log_ok "condarc linked: $(fmt_path "$HOME/.condarc")"
}

step_pip() {
    log_info "link pip config"
    mkdir -p "$HOME/.pip"
    backup_and_link "$REPO_PATH/pip/pip.conf" "$HOME/.pip/pip.conf"
    log_info "repo pip config: $(fmt_path "$REPO_PATH/pip/pip.conf")"
    log_ok "pip config linked: $(fmt_path "$HOME/.pip/pip.conf")"
}

step_vim() {
    log_info "prepare vim config"

    if [ -d "$HOME/.vim/.git" ]; then
        log_info "existing vim config found, updating"
        git -C "$HOME/.vim" fetch
        git -C "$HOME/.vim" pull
    else
        log_info "vim config not found, cloning"
        backup_existing_path "$HOME/.vim"
        backup_existing_path "$HOME/.vimrc"
        git clone "${url_root}hermanzhaozzzz/vim-for-coding.git" "$HOME/.vim"
        ln -s "$HOME/.vim/vimrc" "$HOME/.vimrc"
        log_info "vim config cloned to $(fmt_path "$HOME/.vim")"
    fi

    log_ok "vim config ready"
}

step_nvim() {
    log_info "prepare nvim config"

    if [ -d "$HOME/.config/nvim/.git" ]; then
        log_info "existing nvim config found, updating"
        git -C "$HOME/.config/nvim" fetch
        git -C "$HOME/.config/nvim" pull
    else
        log_info "nvim config not found, cloning"
        mkdir -p "$HOME/.config"
        /bin/rm -rf "$HOME/.cache/nvim" 2>/dev/null
        /bin/rm -rf "$HOME/.local/share/nvim" 2>/dev/null
        /bin/rm -rf "$HOME/.local/state/nvim" 2>/dev/null
        backup_existing_path "$HOME/.config/nvim"
        git clone "${url_root}hermanzhaozzzz/MyLazyVim.git" "$HOME/.config/nvim"
        log_info "nvim config cloned to $(fmt_path "$HOME/.config/nvim")"
    fi

    log_ok "nvim config ready"
}

step_jcat() {
    if [ "$platform" = "Windows" ]; then
        log_warn "jcat is not supported on platform: $platform"
        return 0
    fi

    log_info "prepare jcat"

    if [ ! -x "$REPO_PATH/tools/jcat/jcat" ]; then
        log_info "jcat binary not found, building"
        require_cmd make
        (
            cd "$REPO_PATH/tools/jcat" || exit 1
            make
        ) || fail "jcat build failed"
    else
        log_ok "jcat binary already exists"
    fi

    force_link "$REPO_PATH/tools/jcat/jcat" "$BIN_PATH/jcat"
    log_ok "jcat ready at $(fmt_path "$BIN_PATH/jcat")"
}

step_wd() {
    local dict_root="$HOME/.Wudao-dict"
    local wd_root="$dict_root/wudao-dict"
    local wd_script="$wd_root/wd"

    log_info "prepare wd"

    if [ -d "$dict_root/.git" ]; then
        log_info "existing Wudao-dict found, updating"
        git -C "$dict_root" fetch
        git -C "$dict_root" pull
    else
        log_info "Wudao-dict not found, cloning"
        backup_existing_path "$dict_root"
        git clone "${url_root}hermanzhaozzzz/Wudao-dict.git" "$dict_root"
        pip install bs4 lxml
    fi

    mkdir -p "$wd_root/usr"
    chmod -R 777 "$wd_root/usr"

    cat >"$wd_script" <<EOF
#!/bin/bash
save_path=\$PWD
cd "$wd_root" || exit 1
./wdd "\$@"
cd "\$save_path" || exit 1
EOF
    chmod +x "$wd_script"
    force_link "$wd_script" "$BIN_PATH/wd"
    log_ok "wd ready at $(fmt_path "$BIN_PATH/wd")"
}

step_powershell() {
    local win_profile
    local repo_profile

    if [ "$platform" != "Windows" ]; then
        log_warn "skip PowerShell profile on platform: $platform"
        return 0
    fi

    require_cmd powershell

    win_profile="/c/Program Files/PowerShell/7/profile.ps1"
    repo_profile="$REPO_PATH/powershell/Microsoft.PowerShell_profile.ps1"

    mkdir -p "/c/Program Files/PowerShell/7"
    log_info "link PowerShell profile to $(fmt_path "$win_profile")"
    /bin/rm -rf "$HOME/.condarc" 2>/dev/null
    powershell -File "$repo_profile"
    backup_and_link "$repo_profile" "$win_profile"
    log_ok "PowerShell profile linked from $(fmt_path "$repo_profile")"
}

command_deploy() {
    parse_deploy_args "$@"

    mkdir -p "$BIN_PATH"

    case "$git_method" in
        https)
            url_root="https://github.com/"
            ;;
        ssh)
            url_root="git@github.com:"
            ;;
        *)
            fail "git_method must be one of <https|ssh>"
            ;;
    esac

    SELECTED_STEPS=""
    detect_platform_settings

    if [ "$list_steps" -eq 1 ]; then
        print_available_steps
        exit 0
    fi

    print_section "deployment context"
    print_kv "git" "$git_method"
    print_kv "mode" "$deploy_mode"
    print_kv "platform" "$platform"

    cleanup_legacy_spyder

    choose_steps

    if [ "$platform" = "Windows" ] && [ -z "$SELECTED_STEPS" ] && [ "$use_zprofile_template" -eq 0 ]; then
        log_warn "no steps selected, nothing to do"
        exit 0
    fi

    print_selected_steps
    print_deploy_warnings

    ensure_non_windows_zsh_core

    run_step "micromamba" step_micromamba
    run_step "condarc" step_condarc
    run_step "pip" step_pip
    run_step "vim" step_vim
    run_step "nvim" step_nvim
    run_step "jcat" step_jcat
    run_step "wd" step_wd
    run_step "powershell" step_powershell

    if [ "$use_zprofile_template" -eq 1 ]; then
        apply_zprofile_template
    fi

    refresh_git_install_metadata

    print_section "deployment complete"
    log_ok "all selected steps finished"
    print_selected_steps

    print_section "commands"
    if [ "$platform" = "Windows" ]; then
        print_list_item "run updates in the repo: git-bash ./mse update"
    else
        print_list_item "inside the repo: ./mse deploy"
        print_list_item "inside the repo: ./mse update"
        print_list_item "global after opening a new zsh terminal: mse deploy"
        print_list_item "global after opening a new zsh terminal: mse update"
    fi

    print_section "next steps"
    if [ "$platform" = "Windows" ]; then
        if step_selected "powershell"; then
            print_path_item "open PowerShell to use your environment"
        fi
    else
        print_list_item "open a new zsh session or run: exec zsh"
        if [ "$use_zprofile_template" -eq 1 ]; then
            print_list_item "review ~/.zprofile and replace personal values before long-term use"
        else
            print_list_item "create your own ~/.zprofile for PATH, proxy, tokens, and host-specific aliases"
        fi
    fi

    if step_selected "micromamba"; then
        print_list_item "conda activate base && conda install -f $CONDA_ENVS/base.yml"
    fi

    if [ "$platform" != "Windows" ]; then
        print_list_item "your global command directory is: $BIN_PATH"
    fi

    print_section "tips"
    print_list_item "raise issue on https://github.com/hermanzhaozzzz/.my_shell_envs/issues"

    if [ "$platform" = "Windows" ]; then
        log_warn "this window will close after 300s, you can exit now"
        sleep 300
    fi
}

command_update() {
    load_install_metadata
    parse_update_args "$@"

    if [ "$INSTALL_MODE" = "git" ]; then
        update_from_git
    else
        update_from_archive
    fi
}

main() {
    local command="${1:-help}"

    case "$command" in
        help|-h|--help)
            print_root_usage
            ;;
        deploy)
            shift
            command_deploy "$@"
            ;;
        update)
            shift
            command_update "$@"
            ;;
        *)
            fail "unknown command: $command. Run './mse -h' for help."
            ;;
    esac
}

main "$@"
