step_rust() {
    local rustup_bin="$HOME/.cargo/bin/rustup"
    local cargo_bin="$HOME/.cargo/bin/cargo"
    local rustc_bin="$HOME/.cargo/bin/rustc"
    local active_toolchain=""
    local installed_components=""

    if [ "$platform" = "Windows" ]; then
        log_warn "skip Rust on Windows"
        return 0
    fi

    print_section "ensure Rust toolchain is ready"

    if [ ! -x "$rustup_bin" ]; then
        require_cmd curl
        log_info "rustup not found, starting install without PATH modification"
        curl --proto '=https' --tlsv1.2 -sSf "$RUSTUP_INSTALL_URL" | sh -s -- -y --no-modify-path || fail "Rust installation failed"
    else
        log_ok "rustup already exists at $(fmt_path "$rustup_bin")"
    fi

    [ -x "$rustup_bin" ] || fail "rustup was not installed at $rustup_bin"

    if [ -x "$cargo_bin" ]; then
        log_ok "cargo found at $(fmt_path "$cargo_bin")"
    else
        log_info "cargo not found yet; it will be provided by the Rust stable toolchain"
    fi

    if [ -x "$rustc_bin" ]; then
        log_ok "rustc found at $(fmt_path "$rustc_bin")"
    else
        log_info "rustc not found yet; it will be provided by the Rust stable toolchain"
    fi

    active_toolchain="$("$rustup_bin" show active-toolchain 2>/dev/null | awk '{print $1}')"
    if [ "${active_toolchain%%-*}" = "stable" ]; then
        log_ok "active Rust toolchain is already stable: $active_toolchain"
    else
        log_info "active Rust toolchain is not stable yet; MSE will switch it to stable"
    fi

    "$rustup_bin" toolchain install stable || fail "failed to install Rust stable toolchain"
    "$rustup_bin" default stable || fail "failed to set Rust stable as default"
    log_ok "Rust stable toolchain is available"

    installed_components="$("$rustup_bin" component list --toolchain stable --installed 2>/dev/null || true)"
    if printf '%s\n' "$installed_components" | grep -qx 'rustfmt'; then
        log_ok "Rust component already installed: rustfmt"
    else
        log_info "Rust component missing: rustfmt; installing"
    fi
    if printf '%s\n' "$installed_components" | grep -qx 'clippy'; then
        log_ok "Rust component already installed: clippy"
    else
        log_info "Rust component missing: clippy; installing"
    fi

    "$rustup_bin" component add rustfmt clippy || fail "failed to install rustfmt and clippy"
    log_ok "Rust components are ready: rustfmt, clippy"

    log_ok "Rust is ready under $(fmt_path "$HOME/.cargo/bin")"
}

step_micromamba() {
    local yml
    local found_any=0

    log_info "prepare micromamba and conda env config files"

    if [ "$platform" = "Windows" ]; then
        log_info "Windows installs micromamba via the PowerShell bootstrap step"
    else
        if [ ! -x "$ROOT_PATH/bin/micromamba" ]; then
            log_info "micromamba not found at $(fmt_path "$ROOT_PATH/bin/micromamba"), starting install"
            require_cmd bzip2
            require_cmd curl
            require_cmd tar

            mkdir -p "$ROOT_PATH"
            (
                cd "$ROOT_PATH" || exit 1
                curl -Ls "$MICROMAMBA_URL" | tar -xvj bin/micromamba
            ) || fail "micromamba installation failed"
        else
            log_ok "micromamba already exists at $(fmt_path "$ROOT_PATH/bin/micromamba")"
        fi
    fi

    if [ ! -d "$REPO_PATH/conda/micromamba-pycharm/.git" ]; then
        git clone "${url_root}jonashaag/micromamba-pycharm.git" "$REPO_PATH/conda/micromamba-pycharm"
    else
        log_ok "micromamba-pycharm exists at $(fmt_path "$REPO_PATH/conda/micromamba-pycharm")"
    fi

    log_info "link env yml files for platform $(fmt_step "$platform")"
    mkdir -p "$CONDA_ENVS"

    for yml in "$REPO_PATH"/conda/"$platform"/*.yml; do
        [ -e "$yml" ] || continue
        found_any=1
        if [ "$platform" = "Windows" ]; then
            force_link_windows_native "$yml" "$CONDA_ENVS/$(basename "$yml")"
        else
            force_link "$yml" "$CONDA_ENVS/$(basename "$yml")"
        fi
    done

    if [ "$found_any" -eq 0 ]; then
        log_warn "no env.yml files found for platform: $platform"
    fi

    log_ok "conda env config directory ready: $(fmt_path "$CONDA_ENVS")"
    if [ "$platform" = "Windows" ]; then
        log_ok "Windows micromamba integration files are ready"
    else
        log_ok "micromamba is ready to act as conda / mamba"
    fi
}

