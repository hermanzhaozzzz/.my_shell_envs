parse_deploy_args() {
    git_method="https"
    deploy_mode="fast"
    list_steps=0
    use_zprofile_template=0

    while [ $# -gt 0 ]; do
        case "$1" in
            --https)
                git_method="https"
                ;;
            --ssh)
                git_method="ssh"
                ;;
            --fast)
                deploy_mode="fast"
                ;;
            --interactive)
                deploy_mode="interactive"
                ;;
            --use-zprofile-template)
                use_zprofile_template=1
                ;;
            --git-method)
                shift
                [ $# -gt 0 ] || fail "--git-method requires a value: https or ssh"
                case "$1" in
                    https|ssh)
                        git_method="$1"
                        ;;
                    *)
                        fail "unsupported git method: $1"
                        ;;
                esac
                ;;
            --mode)
                shift
                [ $# -gt 0 ] || fail "--mode requires a value: fast or interactive"
                case "$1" in
                    fast|interactive)
                        deploy_mode="$1"
                        ;;
                    *)
                        fail "unsupported deploy mode: $1"
                        ;;
                esac
                ;;
            --list-steps)
                list_steps=1
                ;;
            -h|--help|help)
                print_deploy_usage
                exit 0
                ;;
            *)
                fail "unknown argument for 'mse deploy': $1. Run './mse deploy -h' for help."
                ;;
        esac
        shift
    done
}

parse_update_args() {
    local opt_name
    local update_git_method=""
    local update_deploy_mode=""
    local update_use_zprofile_template=0
    local update_list_steps=0

    load_persisted_deploy_settings

    update_git_method="$persisted_git_method"
    update_deploy_mode="$persisted_deploy_mode"
    update_use_zprofile_template="$persisted_use_zprofile_template"

    UPDATE_DEPLOY_ARGS=()

    while [ $# -gt 0 ]; do
        case "$1" in
            --https)
                update_git_method="https"
                ;;
            --ssh)
                update_git_method="ssh"
                ;;
            --fast)
                update_deploy_mode="fast"
                ;;
            --interactive)
                update_deploy_mode="interactive"
                ;;
            --use-zprofile-template)
                update_use_zprofile_template=1
                ;;
            --git-method|--mode)
                opt_name="$1"
                shift
                [ $# -gt 0 ] || fail "$opt_name requires a value"
                case "$opt_name" in
                    --git-method)
                        case "$1" in
                            https|ssh)
                                update_git_method="$1"
                                ;;
                            *)
                                fail "unsupported git method: $1"
                                ;;
                        esac
                        ;;
                    --mode)
                        case "$1" in
                            fast|interactive)
                                update_deploy_mode="$1"
                                ;;
                            *)
                                fail "unsupported deploy mode: $1"
                                ;;
                        esac
                        ;;
                esac
                ;;
            --list-steps)
                update_list_steps=1
                ;;
            -h|--help|help)
                print_update_usage
                exit 0
            ;;
            *)
                fail "unknown argument for 'mse update': $1. Run './mse update -h' for help."
                ;;
        esac
        shift
    done

    UPDATE_DEPLOY_ARGS+=(--git-method "$update_git_method")
    UPDATE_DEPLOY_ARGS+=(--mode "$update_deploy_mode")
    if [ "$update_use_zprofile_template" -eq 1 ]; then
        UPDATE_DEPLOY_ARGS+=(--use-zprofile-template)
    fi
    if [ "$update_list_steps" -eq 1 ]; then
        UPDATE_DEPLOY_ARGS+=(--list-steps)
    fi
}

update_from_git() {
    if [ -n "$(git -C "$REPO_PATH" status --porcelain)" ]; then
        fail "git working tree is not clean. Please commit, stash, or remove local changes before running './mse update'."
    fi

    git -C "$REPO_PATH" fetch || fail "git fetch failed"
    git -C "$REPO_PATH" pull --rebase || fail "git pull --rebase failed"

    install_global_wrapper

    MSE_INTERNAL_UPDATE=1 \
    MSE_INTERNAL_SKIP_DEFAULT_SHELL_CHANGE=1 \
    MSE_INTERNAL_SELECTED_STEPS="$persisted_selected_steps" \
    exec "$REPO_PATH/mse" deploy "${UPDATE_DEPLOY_ARGS[@]}"
}

