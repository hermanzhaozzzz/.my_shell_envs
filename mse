ensure_repo_cargo_tool_installed() {
    local crate_name="$1"
    local binary_name="$2"
    local repo_bin_path="$3"
    local display_name="$4"
    local cargo_bin="$HOME/.cargo/bin/cargo"
    local cargo_tool_bin="$HOME/.cargo/bin/$binary_name"
    local current_tool_bin=""

    if [ "$platform" = "Windows" ]; then
        return 0
    fi

    print_section "ensure ${display_name} is installed"

    [ -x "$cargo_bin" ] || fail "cargo is required to install ${display_name} but was not found at $cargo_bin"

    if [ -x "$cargo_tool_bin" ]; then
        log_ok "cargo-installed ${display_name} found at $(fmt_path "$cargo_tool_bin")"
    else
        current_tool_bin="$(command -v "$binary_name" 2>/dev/null || true)"
        if [ -n "$current_tool_bin" ] && [ -x "$current_tool_bin" ]; then
            log_warn "${display_name} exists on this machine at $(fmt_path "$current_tool_bin"), but MSE will install its own copy"
        fi
        log_info "${display_name} not found in the repo-managed toolchain, installing with cargo"
        "$cargo_bin" install "$crate_name" --locked || fail "failed to install ${display_name} with cargo"
    fi

    [ -x "$cargo_tool_bin" ] || fail "${display_name} was not installed at $cargo_tool_bin"
    force_link "$cargo_tool_bin" "$repo_bin_path"
    log_ok "repo bin entry created: $(fmt_path "$repo_bin_path") -> $(fmt_path "$cargo_tool_bin")"
}

