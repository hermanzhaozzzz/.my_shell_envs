                ;;
        esac
    fi
}

detect_platform_settings() {
    local raw_platform
    local arch

    platform=""
    platform_family=""
    MICROMAMBA_URL=""
    ROOT_PATH=""

    raw_platform="$(uname)"
    raw_platform="${raw_platform%%_*}"

    if [ "$raw_platform" = "Linux" ]; then
        platform="Linux"
        MICROMAMBA_URL="https://micro.mamba.pm/api/micromamba/linux-64/latest"
        ROOT_PATH="$HOME/0.apps/micromamba"
    elif [ "$raw_platform" = "Darwin" ]; then
        arch="$(uname -m)"
        if [ "$arch" = "x86_64" ] || [ "$arch" = "i386" ]; then
            platform="MacOS/x86_64"
            MICROMAMBA_URL="https://micro.mamba.pm/api/micromamba/osx-64/latest"
            ROOT_PATH="$HOME/micromamba"
        elif [ "$arch" = "arm64" ] || [ "$arch" = "arm" ]; then
            platform="MacOS/arm64"
            MICROMAMBA_URL="https://micro.mamba.pm/api/micromamba/osx-arm64/latest"
            ROOT_PATH="$HOME/micromamba"
        else
            fail "unsupported MacOS arch: $arch"
        fi
    elif [ "$raw_platform" = "MINGW64" ] || [ "$raw_platform" = "MSYS" ] || [ "$raw_platform" = "CYGWIN" ]; then
        platform="Windows"
    else
        fail "unsupported OS: $raw_platform"
    fi

    platform_family="${platform%%/*}"
}

choose_steps() {
    local step
    local answer
    local step_no=0

    if [ "$internal_update_mode" = "1" ] && [ -n "$selected_steps_override" ]; then
        for step in $selected_steps_override; do
            if step_supported_on_platform "$step"; then
                append_selected_step "$step"
            fi
        done
        if [ -n "$SELECTED_STEPS" ]; then
            log_info "update is reusing the saved step selection from $(fmt_path "$METADATA_FILE")"
            return 0
        fi
        log_warn "saved step selection in $(fmt_path "$METADATA_FILE") does not match this platform"
    fi

    if [ "$internal_update_mode" = "1" ] && [ "$deploy_mode" = "interactive" ]; then
        log_warn "no saved step selection found; update is falling back to fast mode"
        deploy_mode="fast"
    fi

    if [ "$deploy_mode" = "fast" ]; then
        for step in $AVAILABLE_STEPS; do
            if step_supported_on_platform "$step"; then
                append_selected_step "$step"
            fi
        done
        log_info "fast mode selected all supported optional steps automatically"
        return 0
    fi

    print_section "interactive step selection"
    log_info "press y to enable a step, press Enter to skip it"
    for step in $AVAILABLE_STEPS; do
        if ! step_supported_on_platform "$step"; then
            continue
        fi
        step_no=$((step_no + 1))
        printf '  %s %-2s %-12b %s [y/N]: ' "$(badge "$COLOR_BLUE" "STEP")" "$step_no" "$(fmt_step "$step")" "$(describe_step "$step")"
        read answer
        case "$answer" in
            y|Y|yes|YES)
                append_selected_step "$step"
                log_ok "enabled step: $step"
                ;;
            ""|n|N|no|NO)
                log_warn "skipped step: $step"
                ;;
            *)
                log_warn "skipped step: $step"
                ;;
        esac
    done
}

choose_proxy_region() {
    local answer=""

    region="china"
    proxy_mode="clash"
    proxy_port="8234"

    if ! step_selected "cluster_proxy_tools" || [ "$platform" = "Windows" ]; then
        return 0
    fi

    if [ "$internal_update_mode" = "1" ]; then
        region="$persisted_region"
        proxy_mode="$persisted_proxy_mode"
        proxy_port="$persisted_proxy_port"
        log_info "update is reusing saved proxy profile: region=$region mode=$proxy_mode port=$proxy_port"
        return 0
    fi

    if [ "$deploy_mode" = "fast" ]; then
        region="china"
        proxy_mode="clash"
        proxy_port="8234"
        log_info "fast mode uses the default proxy profile: region=$region mode=$proxy_mode port=$proxy_port"
        return 0
    fi

    print_section "cluster proxy profile"
    printf '%s are you in China and planning to use Clash on the login node? [Y/n]: ' "$(badge "$COLOR_BLUE" "ASK")"
    read answer || answer=""
    case "$answer" in
        n|N|no|NO)
            region="global"
            proxy_mode="direct-egress"
            proxy_port="${persisted_proxy_port:-8234}"
            log_info "selected proxy profile: region=$region mode=$proxy_mode"
            print_list_item "no Clash is required"
            print_list_item "compute nodes will use autossh -D to borrow the login node network"
            ;;
        *)
            region="china"
            proxy_mode="clash"
            proxy_port="${persisted_proxy_port:-8234}"
            printf '%s Clash port on the login node [default: %s]: ' "$(badge "$COLOR_BLUE" "ASK")" "$proxy_port"
            read answer || answer=""
            if [ -n "$answer" ]; then
                case "$answer" in
                    *[!0-9]*)
                        log_warn "invalid port '$answer', falling back to $proxy_port"
                        ;;
                    *)
                        proxy_port="$answer"
                        ;;
                esac
            fi
            log_info "selected proxy profile: region=$region mode=$proxy_mode port=$proxy_port"
            print_list_item "remember to start Clash on the login node"
            print_list_item "make sure Clash listens on 127.0.0.1:$proxy_port"
            ;;
    esac
}

run_step() {
    local step="$1"
