export MSE_INSTALL_METADATA_FILE="${MSE_INSTALL_METADATA_FILE:-${HOME}/.my_shell_envs/.mse-install.env}"

_mse_install_pref_value() {
    local key="$1"
    [[ -f "${MSE_INSTALL_METADATA_FILE}" ]] || return 1
    awk -F= -v key="${key}" '
        $1 == key {
            value=$2
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
            gsub(/^["'\'']|["'\'']$/, "", value)
            print value
            exit
        }
    ' "${MSE_INSTALL_METADATA_FILE}"
}

if [[ -z "${MSE_PROXY_MODE:-}" ]]; then
