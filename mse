step_cluster_proxy_tools() {
    local build_stamp="$AUTOSSH_BUILD_DIR/config.status"
    local makefile_path="$AUTOSSH_BUILD_DIR/Makefile"

    if [ "$platform" = "Windows" ]; then
        log_warn "cluster proxy tools are not supported on platform: $platform"
        return 0
    fi

    log_info "prepare cluster proxy tools"
    require_cmd tar
    require_cmd make
    require_cmd gcc

    [ -f "$AUTOSSH_TARBALL_PATH" ] || fail "autossh source tarball not found at $AUTOSSH_TARBALL_PATH"
    [ -d "$PROXYCHAINS_SOURCE_DIR" ] || fail "proxychains-ng source not found at $PROXYCHAINS_SOURCE_DIR"
    [ -x "$PROXYCHAINS_SOURCE_DIR/configure" ] || fail "proxychains-ng configure script not found at $PROXYCHAINS_SOURCE_DIR/configure"
    [ -f "$PROXYCHAINS_CONFIG_PATH" ] || fail "proxychains config not found at $PROXYCHAINS_CONFIG_PATH"

    mkdir -p "$AUTOSSH_BUILD_ROOT"

    if [ ! -d "$AUTOSSH_BUILD_DIR" ]; then
        log_info "extract autossh source"
        tar -xf "$AUTOSSH_TARBALL_PATH" -C "$AUTOSSH_BUILD_ROOT" || fail "failed to extract autossh source"
    else
        log_ok "autossh source already extracted"
    fi

    if [ ! -f "$build_stamp" ] || [ ! -f "$makefile_path" ]; then
        log_info "configure autossh"
        (
            cd "$AUTOSSH_BUILD_DIR" || exit 1
            ./configure --prefix="$AUTOSSH_PREFIX_DIR"
        ) || fail "autossh configure failed"
    else
        log_ok "autossh configure step already completed"
    fi

    if [ ! -x "$AUTOSSH_BIN_PATH" ]; then
        log_info "build and install autossh"
        (
            cd "$AUTOSSH_BUILD_DIR" || exit 1
            make
            make install
        ) || fail "autossh build failed"
    else
        log_ok "autossh binary already exists at $(fmt_path "$AUTOSSH_BIN_PATH")"
    fi

    [ -x "$AUTOSSH_BIN_PATH" ] || fail "autossh was not installed at $AUTOSSH_BIN_PATH"

    if [ ! -x "$PROXYCHAINS_BIN_PATH" ] || [ ! -f "$PROXYCHAINS_LIB_PATH" ]; then
        log_info "configure, build, and install proxychains-ng"
        (
            cd "$PROXYCHAINS_SOURCE_DIR" || exit 1
            ./configure --prefix="$PROXYCHAINS_PREFIX_DIR" --sysconfdir="$PROXYCHAINS_PREFIX_DIR/etc"
            make clean
            make
            make install
            make clean
        ) || fail "proxychains-ng build failed"
    else
        log_ok "proxychains-ng binary already exists at $(fmt_path "$PROXYCHAINS_BIN_PATH")"
    fi

    [ -x "$PROXYCHAINS_BIN_PATH" ] || fail "proxychains-ng binary was not installed at $PROXYCHAINS_BIN_PATH"

    force_link "$AUTOSSH_BIN_PATH" "$REPO_BIN_AUTOSSH_PATH"
    force_link "$PROXYCHAINS_BIN_PATH" "$REPO_BIN_PROXYCHAINS4_PATH"
    force_link "$REPO_BIN_PROXYCHAINS4_PATH" "$REPO_BIN_PROXYCHAINS_PATH"
    if [ "$platform" = "Linux" ] && [ -x "$CLASH_REPO_PATH" ]; then
        force_link "$CLASH_REPO_PATH" "$REPO_BIN_CLASH_PATH"
        log_ok "clash linked at $(fmt_path "$REPO_BIN_CLASH_PATH")"
    elif [ "$platform_family" = "MacOS" ]; then
        log_info "skip repo-managed clash link on macOS"
    elif [ ! -x "$CLASH_REPO_PATH" ]; then
        log_warn "skip clash link because $(fmt_path "$CLASH_REPO_PATH") was not found"
    fi

    log_ok "autossh ready at $(fmt_path "$REPO_BIN_AUTOSSH_PATH")"
    log_ok "proxychains4 linked at $(fmt_path "$REPO_BIN_PROXYCHAINS4_PATH")"
    log_ok "proxychains compatibility link ready at $(fmt_path "$REPO_BIN_PROXYCHAINS_PATH")"
}

step_wd() {
    local dict_root="$HOME/.Wudao-dict"
    local wd_root="$dict_root/wudao-dict"
    local wd_script="$BIN_PATH/wd"

    log_info "prepare wd"

    if [ -d "$dict_root/.git" ]; then
        log_info "existing Wudao-dict found, updating"
        git -C "$dict_root" fetch
        git -C "$dict_root" pull
    else
        log_info "Wudao-dict not found, cloning"
        backup_existing_path "$dict_root"
        git clone "${url_root}hermanzhaozzzz/Wudao-dict.git" "$dict_root"
        install_python_packages_if_available bs4 lxml
    fi

    mkdir -p "$wd_root/usr"
    chmod -R 777 "$wd_root/usr"
    mkdir -p "$BIN_PATH"

    if [ -L "$wd_script" ]; then
        /bin/rm -f "$wd_script" || fail "failed to replace symlink at $wd_script"
    elif [ -e "$wd_script" ] && [ ! -f "$wd_script" ]; then
        fail "cannot write wd wrapper to $wd_script because it is not a regular file"
    fi

    cat >"$wd_script" <<EOF
#!/bin/bash
save_path=\$PWD
cd "$wd_root" || exit 1
./wdd "\$@"
cd "\$save_path" || exit 1
EOF
    chmod +x "$wd_script"
    log_ok "wd ready at $(fmt_path "$wd_script")"
}

